\nimport pandas as pd\nfrom tensorflow.keras.models import load_model\n\n# 1. Khai bao duong dan model Sobel va ten cac cot Softmax\nINPUT_DIR = '/kaggle/input/datasets/tintrancong/models-saved/Models'\nmodel_path = os.path.join(INPUT_DIR, 'model_densenet121_sobel.keras')\n\ntarget_names = ['XR_ELBOW', 'XR_FINGER', 'XR_FOREARM', 'XR_HAND', 'XR_HUMERUS', 'XR_SHOULDER', 'XR_WRIST']\nsoftmax_cols = [f'prob_{name}' for name in target_names]\n\n# 2. Load mo hinh vo dich\nprint(\"Loading Champion Model: DenseNet121 + Sobel...\")\nmodel = load_model(model_path)\n\n# 3. Ham tao Generator va trich xuat Vector\ndef extract_softmax_features(df, model, batch_size=32):\n    print(f\"Processing {len(df)} images...\")\n    # Generator dac biet KHONG augment (de giu nguyen thu tu)\n    gen = EdgeDataGenerator(\n        df=df, \n        x_col='img_path', \n        y_col='label_idx',\n        batch_size=batch_size, \n        target_size=(224, 224), \n        num_classes=7, \n        augment=False, # BAT BUOC FALSE DE KHONG SHUFFLE\n        edge_filter=apply_sobel_eda\n    )\n    \n    # Predict de lay mang probabilities\n    predictions = model.predict(gen, verbose=1)\n    \n    # Tao ban sao cua dataframe de khong lam hong data goc\n    new_df = df.copy()\n    \n    # Ghep 7 cot xac suat vao dataframe\n    for i, col in enumerate(softmax_cols):\n        new_df[col] = predictions[:, i]\n        \n    return new_df\n\n# 4. Thuc thi cho ca Train va Valid\nprint(\"\\n--- Extracting for Training Set ---\")\ntrain_df_with_softmax = extract_softmax_features(final_train_df, model)\n\nprint(\"\\n--- Extracting for Validation Set ---\")\nvalid_df_with_softmax = extract_softmax_features(final_valid_df, model)\n\n# 5. Luu thanh file CSV\ntrain_df_with_softmax.to_csv('final_train_with_softmax.csv', index=False)\nvalid_df_with_softmax.to_csv('final_valid_with_softmax.csv', index=False)\n\nprint(\"\\nSuccess! Saved 2 files: 'final_train_with_softmax.csv' and 'final_valid_with_softmax.csv'\")\ndisplay(train_df_with_softmax.head())","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-26T14:56:40.469405Z","iopub.execute_input":"2026-04-26T14:56:40.469957Z","iopub.status.idle":"2026-04-26T15:11:03.310044Z","shell.execute_reply.started":"2026-04-26T14:56:40.469928Z","shell.execute_reply":"2026-04-26T15:11:03.309142Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 2:  Data Generator (Multi-Input)","metadata":{}},{"cell_type":"code","source":"import numpy as np\nimport pandas as pd\nimport cv2\nfrom tensorflow.keras.utils import Sequence\nfrom tensorflow.keras.applications.densenet import preprocess_input\n\n# 1. Load data\nprint(\"Loading data for Model 2...\")\ntrain_df = pd.read_csv('/kaggle/input/datasets/tintrancong/softmax-saved/Softmax/final_train_with_softmax.csv')\nvalid_df = pd.read_csv('/kaggle/input/datasets/tintrancong/softmax-saved/Softmax/final_valid_with_softmax.csv')\n\ntarget_names = ['XR_ELBOW', 'XR_FINGER', 'XR_FOREARM', 'XR_HAND', 'XR_HUMERUS', 'XR_SHOULDER', 'XR_WRIST']\nsoftmax_cols = [f'prob_{name}' for name in target_names]\n\nLABEL_COL = 'label' if 'label' in train_df.columns else 'Label'\n\n# 2. Xay dung Class Generator \nclass MultiInputGenerator(Sequence):\n    def __init__(self, df, img_col='img_path', label_col=LABEL_COL, vec_cols=softmax_cols,\n                 batch_size=32, target_size=(224, 224), shuffle=True, use_sobel=False, **kwargs):\n        # FIX 1: Goi ham khoi tao cua lop cha de xoa Warning\n        super().__init__(**kwargs) \n        \n        self.df = df\n        self.img_col = img_col\n        self.label_col = label_col\n        self.vec_cols = vec_cols\n        self.batch_size = batch_size\n        self.target_size = target_size\n        self.shuffle = shuffle\n        self.use_sobel = use_sobel\n        self.indices = np.arange(len(self.df))\n        if self.shuffle:\n            np.random.shuffle(self.indices)\n            \n    def __len__(self):\n        return int(np.ceil(len(self.df) / self.batch_size))\n    \n    def on_epoch_end(self):\n        if self.shuffle:\n            np.random.shuffle(self.indices)\n            \n    def apply_sobel(self, img):\n        gray = cv2.cvtColor(img, cv2.COLOR_RGB2GRAY)\n        sobelx = cv2.Sobel(gray, cv2.CV_64F, 1, 0, ksize=3)\n        sobely = cv2.Sobel(gray, cv2.CV_64F, 0, 1, ksize=3)\n        sobel_combined = cv2.magnitude(sobelx, sobely)\n        sobel_normalized = cv2.normalize(sobel_combined, None, 0, 255, cv2.NORM_MINMAX, dtype=cv2.CV_8U)\n        return cv2.cvtColor(sobel_normalized, cv2.COLOR_GRAY2RGB)\n\n    def __getitem__(self, index):\n        batch_indices = self.indices[index * self.batch_size : (index + 1) * self.batch_size]\n        batch_df = self.df.iloc[batch_indices]\n        \n        X_images, X_vectors, y_labels = [], [], []\n        \n        for _, row in batch_df.iterrows():\n            # Xu ly Anh\n            img = cv2.imread(row[self.img_col])\n            img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)\n            img = cv2.resize(img, self.target_size)\n            \n            if self.use_sobel:\n                img = self.apply_sobel(img)\n                \n            img = preprocess_input(img.astype(np.float32))\n            X_images.append(img)\n            \n            # Xu ly Vector va Label\n            X_vectors.append(row[self.vec_cols].values.astype(np.float32))\n            y_labels.append(row[self.label_col])\n            \n        # FIX 2: Thay doi List [] thanh Tuple () cho phan Input de tranh loi TypeError\n        return (np.array(X_images), np.array(X_vectors)), np.array(y_labels).astype(np.float32)\n\n# 3. Generator\nprint(\"Initializing Original Image Generators\")\ntrain_gen = MultiInputGenerator(train_df, batch_size=32, shuffle=True, use_sobel=False)\nvalid_gen = MultiInputGenerator(valid_df, batch_size=32, shuffle=False, use_sobel=False)\n\n# Chạy lại khởi tạo Generator, bật tính năng Sobel\n#print(\"Initializing SOBEL Image Generators...\")\n\n#train_gen_sobel = MultiInputGenerator(train_df, batch_size=32, shuffle=True, use_sobel=True)\n#valid_gen_sobel = MultiInputGenerator(valid_df, batch_size=32, shuffle=False, use_sobel=True)\n\n#print(\"Sobel Generators ready!\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-26T15:27:15.069126Z","iopub.execute_input":"2026-04-26T15:27:15.069869Z","iopub.status.idle":"2026-04-26T15:27:15.3012Z","shell.execute_reply.started":"2026-04-26T15:27:15.069839Z","shell.execute_reply":"2026-04-26T15:27:15.300238Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 4: Model 2 - Normal/Abnormal","metadata":{}},{"cell_type":"markdown","source":"## Cell 4.1: DenseNet121 (Original Weight) + Softmax Vector","metadata":{}},{"cell_type":"code","source":"from tensorflow.keras.layers import Input, Dense, GlobalAveragePooling2D, Concatenate, Dropout\nfrom tensorflow.keras.models import Model\nfrom tensorflow.keras.applications import DenseNet121\nfrom tensorflow.keras.optimizers import Adam\nfrom tensorflow.keras import regularizers \n\ndef build_multi_input_model_with_reg():\n    image_input = Input(shape=(224, 224, 3), name='image_input')\n    \n    base_model = DenseNet121(weights=None, include_top=False, input_tensor=image_input)\n    \n    path_to_original_weights = '/kaggle/input/datasets/tintrancong/models-saved/Models/model_densenet121.keras' \n    base_model.load_weights(path_to_original_weights)\n    print(f\"Successfully loaded X-Ray weights from {path_to_original_weights}\")\n    \n    for layer in base_model.layers:\n        layer.trainable = False\n        \n    x1 = GlobalAveragePooling2D(name='image_features')(base_model.output)\n    \n    vector_input = Input(shape=(7,), name='vector_input')\n    x2 = Dense(16, activation='relu', name='vector_features')(vector_input)\n    \n    merged = Concatenate(name='concat_features')([x1, x2])\n    z = Dense(256, activation='relu', name='dense_classifier')(merged)\n    z = Dropout(0.5)(z)\n    \n    final_output = Dense(1, activation='sigmoid', \n                         kernel_regularizer=regularizers.l2(1e-3), \n                         name='final_output')(z)\n    \n    model = Model(inputs=[image_input, vector_input], outputs=final_output, name=\"Model2_FineTuned_Reg\")\n    return model\n\nmodel_2_reg = build_multi_input_model_with_reg()\n\nmodel_2_reg.compile(\n    optimizer=Adam(learning_rate=1e-5), \n    loss='binary_crossentropy',\n    metrics=['accuracy']\n)\n\nmodel_2_reg.summary()\nprint(\"\\nModel with Regularization is successfully built and compiled! Ready for training.\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-26T14:56:03.191887Z","iopub.execute_input":"2026-04-26T14:56:03.192357Z","iopub.status.idle":"2026-04-26T14:56:06.162848Z","shell.execute_reply.started":"2026-04-26T14:56:03.192329Z","shell.execute_reply":"2026-04-26T14:56:06.161959Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 4.1.1: Train Model 2 - Baseline_DenseNet121 (Original Image + Vector)","metadata":{}},{"cell_type":"code","source":"from tensorflow.keras.callbacks import ModelCheckpoint, EarlyStopping, CSVLogger\n\ncheckpoint_path = \"model2_baseline_original_best.keras\"\ncsv_log_path = \"training_logs_model2_baseline_original.csv\"\n\n# 1. Callbacks\ncallbacks = [\n    ModelCheckpoint(\n        filepath=checkpoint_path,\n        monitor='val_accuracy', \n        save_best_only=True,    \n        mode='max',\n        verbose=1\n    ),\n    EarlyStopping(\n        monitor='val_loss',     \n        patience=5,             \n        restore_best_weights=True,\n        verbose=1\n    ),\n    CSVLogger(\n        filename=csv_log_path,  \n        separator=',',\n        append=False            \n    )\n]\n\nprint(\"Starting training for Model 2 Baseline (Original Image + Vector)\")\nepochs = 20 \n\nhistory = model_2_baseline.fit(\n    train_gen,                    \n    validation_data=valid_gen,    \n    epochs=epochs,\n    callbacks=callbacks,\n    verbose=1\n)\n\nprint(f\"\\nTraining completed successfully! Logs are saved to {csv_log_path}\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 4.1.2: Model 2_Baseline_DenseNet121 (Original Images)_Evaluation","metadata":{}},{"cell_type":"code","source":"import numpy as np\nimport pandas as pd\nimport matplotlib.pyplot as plt\nimport seaborn as sns\nfrom sklearn.metrics import confusion_matrix, classification_report\n\n# 1. Ham ve va LUU bieu do Lich su huan luyen\ndef plot_training_history(history):\n    fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(14, 5))\n    \n    # Bieu do Accuracy\n    ax1.plot(history.history['accuracy'], label='Train Accuracy', color='blue')\n    ax1.plot(history.history['val_accuracy'], label='Validation Accuracy', color='orange')\n    ax1.set_title('Model Accuracy')\n    ax1.set_xlabel('Epochs')\n    ax1.set_ylabel('Accuracy')\n    ax1.legend()\n    \n    # Bieu do Loss\n    ax2.plot(history.history['loss'], label='Train Loss', color='blue')\n    ax2.plot(history.history['val_loss'], label='Validation Loss', color='orange')\n    ax2.set_title('Model Loss')\n    ax2.set_xlabel('Epochs')\n    ax2.set_ylabel('Loss')\n    ax2.legend()\n    \n    plt.tight_layout()\n    plt.savefig('training_history_model2_baseline.png', dpi=300)\n    print(\"Saved training history plot to 'training_history_model2_baseline.png'\")\n    \n    plt.show()\n\nprint(\"--- 1. Training History Plots ---\")\nplot_training_history(history)\n\n# 2. Chuan bi du lieu de danh gia\nprint(\"\\n--- 2. Predicting on Validation Set ---\")\n# Cập nhật đúng tên file weights của mô hình Baseline vừa train\ncheckpoint_path = \"model2_baseline_original_best.keras\"\nmodel_2_baseline.load_weights(checkpoint_path)\n\n# Tien hanh du doan \ny_pred_prob = model_2_baseline.predict(valid_gen, verbose=1)\ny_pred = (y_pred_prob > 0.5).astype(int).flatten()\n\nLAB