ain_df['img_path'].str.contains('XR_WRIST')) & (train_df[LABEL_COL] == 1)].iloc[6]['img_path']\n\nnorm_orig, norm_lp, norm_hp = apply_filters(wrist_normal)\nabnorm_orig, abnorm_lp, abnorm_hp = apply_filters(wrist_abnormal)\n\nfig, axes = plt.subplots(2, 3, figsize=(15, 10))\nfig.suptitle('Feature Extraction Comparison: Normal vs Abnormal (XR_WRIST)', fontsize=16, fontweight='bold', color='darkred')\n\naxes[0, 0].imshow(norm_orig, cmap='gray')\naxes[0, 0].set_title('Normal - Original')\naxes[0, 1].imshow(norm_lp, cmap='gray')\naxes[0, 1].set_title('Normal - Low Pass (Gaussian)')\naxes[0, 2].imshow(norm_hp, cmap='gray')\naxes[0, 2].set_title('Normal - High Pass (Laplacian)')\n\naxes[1, 0].imshow(abnorm_orig, cmap='gray')\naxes[1, 0].set_title('Abnormal - Original')\naxes[1, 1].imshow(abnorm_lp, cmap='gray')\naxes[1, 1].set_title('Abnormal - Low Pass (Gaussian)')\naxes[1, 2].imshow(abnorm_hp, cmap='gray')\naxes[1, 2].set_title('Abnormal - High Pass (Laplacian)')\n\nfor ax in axes.flatten():\n    ax.axis('off')\n\nplt.tight_layout()\nplt.savefig('filter_comparison.png', dpi=300)\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-26T20:03:10.029832Z","iopub.execute_input":"2026-04-26T20:03:10.030404Z","iopub.status.idle":"2026-04-26T20:03:13.159205Z","shell.execute_reply.started":"2026-04-26T20:03:10.030371Z","shell.execute_reply":"2026-04-26T20:03:13.158209Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 5.2: EXTRACTING SOFTMAX CONDITIONS FROM MODEL 1 ","metadata":{}},{"cell_type":"code","source":"import os\nimport cv2\nimport numpy as np\nimport pandas as pd\nfrom tensorflow.keras.models import load_model\n\nprint(\"--- STEP 1: EXTRACTING SOFTMAX CONDITIONS FROM MODEL 1 ---\")\n\nMODEL_1_PATH = '/kaggle/input/datasets/tintrancong/models-saved/Models/model_densenet121.keras' \nprint(\"Loading Model 1 (DenseNet121)...\")\nmodel_1 = load_model(MODEL_1_PATH)\n\nbody_parts = ['XR_ELBOW', 'XR_FINGER', 'XR_FOREARM', 'XR_HAND', 'XR_HUMERUS', 'XR_SHOULDER', 'XR_WRIST']\nsoftmax_columns = [f'prob_{part}' for part in body_parts]\n\ndef add_softmax_probabilities(df, model, target_size=(224, 224), base_path=\"/kaggle/input/datasets/tintrancong/ai-powered-musculoskeletal-injury-dataset/Final_Project_TranCongTinCOS1106\"):\n    print(f\"Processing {len(df)} images...\")\n    all_preds = []\n    batch_size = 32\n    \n    for i in range(0, len(df), batch_size):\n        batch_paths = df['img_path'].iloc[i:i+batch_size]\n        batch_images = []\n        for path in batch_paths:\n            full_path = os.path.join(base_path, path) if not path.startswith('/kaggle/input') else path\n            img = cv2.imread(full_path)\n            if img is not None:\n                img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)\n                img = cv2.resize(img, target_size)\n                batch_images.append(img)\n        \n        preds = model.predict(np.array(batch_images), verbose=0)\n        all_preds.extend(preds)\n        \n    pred_df = pd.DataFrame(all_preds, columns=softmax_columns)\n    return pd.concat([df.reset_index(drop=True), pred_df], axis=1)\n\nprint(\"2. Predicting for Train Set...\")\nfinal_train_df = add_softmax_probabilities(final_train_df, model_1)\n\nprint(\"3. Predicting for Validation Set...\")\nfinal_valid_df = add_softmax_probabilities(final_valid_df, model_1)\n\nprint(\"4. Predicting for Test Set...\")\ntest_df = add_softmax_probabilities(test_df, model_1)\n\nprint(\"Softmax columns added to all DataFrames!\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-26T20:04:36.265218Z","iopub.execute_input":"2026-04-26T20:04:36.266032Z","iopub.status.idle":"2026-04-26T20:22:21.328133Z","shell.execute_reply.started":"2026-04-26T20:04:36.265945Z","shell.execute_reply":"2026-04-26T20:22:21.327136Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 5.3: CONDITIONAL GENERATORS","metadata":{}},{"cell_type":"code","source":"from tensorflow.keras.utils import Sequence\n\nprint(\"--- STEP 2: INITIALIZING CONDITIONAL GENERATORS ---\")\n\nfinal_train_normal_df = final_train_df[final_train_df['Label'] == 0].reset_index(drop=True)\nprint(f\"Total Train images: {len(final_train_df)} | Normal images for Autoencoder: {len(final_train_normal_df)}\")\n\nclass ConditionalAutoencoderGenerator(Sequence):\n    def __init__(self, df, img_col='img_path', vec_cols=None, batch_size=32, target_size=(224, 224), shuffle=True, **kwargs):\n        super().__init__(**kwargs) \n        self.df = df\n        self.img_col = img_col\n        self.vec_cols = vec_cols\n        self.batch_size = batch_size\n        self.target_size = target_size\n        self.shuffle = shuffle\n        self.indices = np.arange(len(self.df))\n        self.base_path = \"/kaggle/input/datasets/tintrancong/ai-powered-musculoskeletal-injury-dataset/Final_Project_TranCongTinCOS1106\"\n        if self.shuffle: np.random.shuffle(self.indices)\n            \n    def __len__(self):\n        return int(np.ceil(len(self.df) / self.batch_size))\n    \n    def on_epoch_end(self):\n        if self.shuffle: np.random.shuffle(self.indices)\n\n    def __getitem__(self, index):\n        batch_indices = self.indices[index * self.batch_size : (index + 1) * self.batch_size]\n        batch_df = self.df.iloc[batch_indices]\n        \n        X_images, X_vectors = [], []\n        for _, row in batch_df.iterrows():\n            img_path = row[self.img_col]\n            full_path = os.path.join(self.base_path, img_path) if not img_path.startswith('/kaggle/input') else img_path\n            \n            img = cv2.imread(full_path)\n            if img is None: continue\n                \n            img = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY) \n            img = cv2.resize(img, self.target_size)\n            img = np.expand_dims(img, axis=-1)\n            img = img.astype(np.float32) / 255.0\n            \n            X_images.append(img)\n            if self.vec_cols:\n                X_vectors.append(row[self.vec_cols].values.astype(np.float32))\n                \n        X_images = np.array(X_images)\n        if self.vec_cols:\n            X_vectors = np.array(X_vectors)\n            return (X_images, X_vectors), X_images # Output: ([Image, Condition], Target_Image)\n        return X_images, X_images\n\n# Generators\nauto_train_gen = ConditionalAutoencoderGenerator(final_train_normal_df, vec_cols=softmax_columns, batch_size=32, shuffle=True)\nauto_valid_gen = ConditionalAutoencoderGenerator(final_valid_df, vec_cols=softmax_columns, batch_size=32, shuffle=False)\nauto_test_gen = ConditionalAutoencoderGenerator(test_df, vec_cols=softmax_columns, batch_size=32, shuffle=False)\n\nprint(\"All Generators are ready!\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-26T20:22:24.598652Z","iopub.execute_input":"2026-04-26T20:22:24.599679Z","iopub.status.idle":"2026-04-26T20:22:24.623721Z","shell.execute_reply.started":"2026-04-26T20:22:24.599645Z","shell.execute_reply":"2026-04-26T20:22:24.622606Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 5.4: HYPERPARAMETER TUNING BEFORE TRAINING","metadata":{}},{"cell_type":"code","source":"!pip install keras-tuner -q\nimport keras_tuner as kt\nfrom tensorflow.keras.layers import Input, Conv2D, Flatten, Dense, Reshape, Conv2DTranspose, Concatenate\nfrom tensorflow.keras.models import Model\nfrom tensorflow.keras.optimizers import Adam\nimport numpy as np\n\nprint(\"--- STEP 3: HYPERPARAMETER TUNING ---\")\n\ndef build_tuner_model(hp):\n    latent_dim = hp.Choice('latent_dim', values=[256, 512])\n    \n    # 1. ENCODER\n    input_img = Input(shape=(224, 224, 1), name='image_input')\n    x = Conv2D(32, (3, 3), activation='relu', padding='same', strides=2)(input_img)   \n    x = Conv2D(64, (3, 3), activation='relu', padding='same', strides=2)(x)           \n    x = Conv2D(128, (3, 3), activation='relu', padding='same', strides=2)(x)          \n    x = Conv2D(128, (3, 3), activation='relu', padding='same', strides=2)(x)          \n    encoded_shape = x.shape[1:] \n    x = Flatten()(x)            \n    latent_vector = Dense(latent_dim, activation='relu', name='latent_features')(x)\n\n    # 2. BOTTLENECK\n    input_cond = Input(shape=(7,), name='condition_input')\n    merged_vector = Concatenate(name='merge_features_and_condition')([latent_vector, input_cond])\n\n    # 3. DECODER\n    x = Dense(np.prod(encoded_shape), activation='relu')(merged_vector)\n    x = Reshape(encoded_shape)(x)\n    x = Conv2DTranspose(128, (3, 3), activation='relu', padding='same', strides=2)(x) \n    x = Conv2DTranspose(64, (3, 3), activation='relu', padding='same', strides=2)(x)  \n    x = Conv2DTranspose(32, (3, 3), activation='relu', padding='same', strides=2)(x)  \n    decoded_img = Conv2DTranspose(1, (3, 3), activation='sigmoid', padding='same', strides=2, name='reconstructed_image')(x)\n\n    autoencoder = Model(inputs=[input_img, input_cond], outputs=decoded_img)\n    \n    hp_learning_rate = hp.Choice('learning_rate', values=[1e-3, 1e-4, 1e-5])\n    autoencoder.compile(optimizer=Adam(learning_rate=hp_learning_rate), loss='mse')\n    \n    return autoencoder\n\ntuner = kt.RandomSearch(\n    build_tuner_model,\n    objective='val_loss',\n    max_trials=3,\n    executions_per_trial=1,\n    directory='autoencoder_tuning',\n    project_name='bone_anomaly'\n)\n\ntuner.search(auto_train_gen, validation_data=auto_valid_gen, epochs=3)\n\nbest_hps = tuner.get_best_hyperparameters(num_trials=1)[0]\nprint(f\" TUNING COMPLETE! Best Latent Dim: {best_hps.get('latent_dim')}\")\nprint(f\" TUNING COMPLETE! Best Learning Rate: {best_hps.get('learning_rate')}\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 5.5: TRAINING AUTOENCODER","metadata":{}},{"cell_type":"code","source":"from tensorflow.keras.callbacks import EarlyStopping, ModelCheckpoint, ReduceLROnPlateau, CSV