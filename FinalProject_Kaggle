:\n        self.df = df\n        self.batch_size = batch_size\n        self.target_size = target_size\n        self.shuffle = shuffle\n        self.indices = np.arange(len(self.df))\n        if self.shuffle: np.random.shuffle(self.indices)\n\n    def __len__(self): return int(np.ceil(len(self.df) / self.batch_size))\n    def on_epoch_end(self): \n        if self.shuffle: np.random.shuffle(self.indices)\n\n    def __getitem__(self, index):\n        batch_indices = self.indices[index * self.batch_size : (index + 1) * self.batch_size]\n        batch_df = self.df.iloc[batch_indices]\n        X, y = [], []\n        BASE_DATA_DIR = '/kaggle/input/datasets/tintrancong/ai-powered-musculoskeletal-injury-dataset/Final_Project_TranCongTinCOS1106' \n\n        for _, row in batch_df.iterrows():\n            img_path = os.path.join(BASE_DATA_DIR, row['img_path']) \n            gray_img = cv2.imread(img_path, cv2.IMREAD_GRAYSCALE)\n            if gray_img is None: continue\n            \n            gray_img = cv2.resize(gray_img, self.target_size)\n            orig = gray_img / 255.0\n            low = cv2.GaussianBlur(gray_img, (5, 5), 0) / 255.0\n            high = cv2.Laplacian(gray_img, cv2.CV_32F)\n            high = cv2.normalize(high, None, 0, 1, cv2.NORM_MINMAX)\n            \n            img_3c = np.stack([orig, low, high], axis=-1)\n            X.append(img_3c)\n            y.append(row['Target_14'])\n\n        X = np.array(X, dtype=np.float32)\n        y = tf.keras.utils.to_categorical(y, num_classes=14)\n        return X, y\n\nclass ViT_HubLayer(tf.keras.layers.Layer):\n    def __init__(self, url=\"https://tfhub.dev/sayakpaul/vit_b16_fe/1\", **kwargs):\n        super().__init__(**kwargs)\n        self.url = url\n        self.model = hub.load(url)\n        self.trainable = False\n    def call(self, inputs): return self.model(inputs)\n    def get_config(self):\n        config = super().get_config()\n        config.update({\"url\": self.url})\n        return config\n\nprint(\"Valid & Test Generators\")\nvalid_gen_14 = DenseNet14ClassGenerator(valid_14_df, batch_size=32, shuffle=False)\ntest_gen_14 = DenseNet14ClassGenerator(test_14_df, batch_size=32, shuffle=False)\n\ny_true_valid = valid_14_df['Target_14'].values\ny_true_test = test_14_df['Target_14'].values\n\nmodels_to_evaluate = {\n    \"DenseNet121 (Transfer Learning)\": \"/kaggle/input/datasets/tintrancong/models-saved/Models/model_14classes_densenet121.keras\",\n    \"DenseNet121 (Fine-tuned)\": \"/kaggle/input/datasets/tintrancong/models-saved/Models/model_14classes_densenet121_finetuned.keras\",\n    \"Vision Transformer (ViT)\": \"/kaggle/input/datasets/tintrancong/models-saved/Models/vit_14classes_best.keras\"\n}\n\nvalid_results = []\ntest_y_preds_all = {} \n\nprint(\"Evaluate\")\nfor model_name, model_path in models_to_evaluate.items():\n    print(f\"\\n[Processing] {model_name}...\")\n    try:\n        if \"ViT\" in model_name:\n            model = load_model(model_path, custom_objects={'ViT_HubLayer': ViT_HubLayer})\n        else:\n            model = load_model(model_path)\n        valid_probs = model.predict(valid_gen_14, verbose=0)\n        y_pred_valid = np.argmax(valid_probs, axis=1)\n        \n        acc = accuracy_score(y_true_valid, y_pred_valid)\n        prec = precision_score(y_true_valid, y_pred_valid, average='weighted', zero_division=0)\n        rec = recall_score(y_true_valid, y_pred_valid, average='weighted', zero_division=0)\n        f1 = f1_score(y_true_valid, y_pred_valid, average='weighted', zero_division=0)\n        \n        valid_results.append({\n            \"Model\": model_name, \"Accuracy\": acc, \n            \"Precision\": prec, \"Recall\": rec, \"F1 Score\": f1\n        })\n        \n        test_probs = model.predict(test_gen_14, verbose=0)\n        test_y_preds_all[model_name] = np.argmax(test_probs, axis=1)\n        \n        print(\" -> Hoàn tất mô hình này!\")\n        \n    except Exception as e:\n        print(f\" -> LỖI khi chạy {model_name}: {e}\")\n\nif valid_results:\n    # --- 4.1 BẢNG SO SÁNH (TẬP VALIDATION) ---\n    results_df = pd.DataFrame(valid_results)\n    results_df.to_csv('/kaggle/working/approach4_14classes_VALID_comparison.csv', index=False)\n    \n    fig_table, ax_table = plt.subplots(figsize=(12, 3)) \n    ax_table.axis('off') \n    \n    rounded_df = results_df.copy()\n    for col in [\"Accuracy\", \"Precision\", \"Recall\", \"F1 Score\"]:\n        rounded_df[col] = rounded_df[col].apply(lambda x: f\"{x:.4f}\")\n\n    col_widths = [0.4, 0.15, 0.15, 0.15, 0.15]\n    table = ax_table.table(cellText=rounded_df.values, colLabels=rounded_df.columns,\n                           cellLoc='center', loc='center', colWidths=col_widths, bbox=[0, 0, 1, 1])\n    table.auto_set_font_size(False)\n    table.set_fontsize(11)\n\n    for (row, col), cell in table.get_celld().items():\n        if row == 0:\n            cell.set_text_props(weight='bold', color='white')\n            cell.set_facecolor('#8B0000') \n        else:\n            if col == 0: cell.set_text_props(ha='left')\n            cell.set_facecolor('#FFE4E1' if row % 2 == 0 else '#ffffff')\n\n    plt.title('Approach 4 Comparison (Validation Set)', fontsize=14, fontweight='bold', pad=20)\n    plt.tight_layout()\n    plt.savefig('/kaggle/working/approach4_14classes_VALID_table.png', dpi=300, bbox_inches='tight')\n    plt.show()\n\n    for model_name, y_pred_test in test_y_preds_all.items():\n        cm = confusion_matrix(y_true_test, y_pred_test)\n        plt.figure(figsize=(14, 12))\n        \n        cmap_color = 'Oranges' if 'ViT' in model_name else 'Blues'\n        \n        sns.heatmap(cm, annot=True, fmt='d', cmap=cmap_color, \n                    xticklabels=target_names, yticklabels=target_names,\n                    linewidths=0.5, linecolor='gray')\n                    \n        plt.title(f'Confusion Matrix (Test Set) - {model_name}', fontsize=16, fontweight='bold')\n        plt.ylabel('Actual Label (True)', fontsize=1