y.started":"2026-04-26T19:31:00.82248Z","shell.execute_reply":"2026-04-26T19:31:01.695812Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"import numpy as np\nimport matplotlib.pyplot as plt\nfrom sklearn.metrics import roc_curve, auc\nfrom tensorflow.keras.models import load_model\n\n# 1. Load model Autoencoder\nmodel_path = '/kaggle/input/datasets/tintrancong/models-saved/Models/conditional_autoencoder_hyper_best.keras' \nautoencoder = load_model(model_path, compile=False)\n\nreconstructed_images = autoencoder.predict(auto_valid_gen, verbose=1)\n\nX_valid_list = []\nfor i in range(len(auto_valid_gen)):\n    inputs, target = auto_valid_gen[i]\n    X_valid_list.append(target) \n\nX_valid_original = np.vstack(X_valid_list)\n\nprint(\"Đang tính toán Reconstruction Error (MSE)...\")\nmse_errors = np.mean(np.square(X_valid_original - reconstructed_images), axis=(1, 2, 3))\ny_true_valid = final_valid_df['Label'].values[:len(mse_errors)]\n\nfpr, tpr, thresholds = roc_curve(y_true_valid, mse_errors)\nroc_auc = auc(fpr, tpr)\n\nplt.figure(figsize=(8, 6))\nplt.plot(fpr, tpr, color='darkorange', lw=2, label=f'ROC curve (AUC = {roc_auc:.4f})')\nplt.plot([0, 1], [0, 1], color='navy', lw=2, linestyle='--', label='Random Guess')\n\nplt.xlim([0.0, 1.0])\nplt.ylim([0.0, 1.05])\nplt.xlabel('False Positive Rate (FPR)', fontsize=12)\nplt.ylabel('True Positive Rate (TPR)', fontsize=12)\nplt.title('ROC Curve - Conditional Autoencoder (Validation Set)', fontsize=14, fontweight='bold')\nplt.legend(loc=\"lower right\", fontsize=11)\nplt.grid(True, linestyle='--', alpha=0.6)\n\nplt.tight_layout()\nplt.savefig('/kaggle/working/roc_curve_conditional_autoencoder.png', dpi=300)\nplt.show()\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-26T20:22:33.348546Z","iopub.execute_input":"2026-04-26T20:22:33.349176Z","iopub.status.idle":"2026-04-26T20:24:13.015684Z","shell.execute_reply.started":"2026-04-26T20:22:33.349148Z","shell.execute_reply":"2026-04-26T20:24:13.014755Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 5.7: ENHANCE CONDITIONAL GENERATORS","metadata":{}},{"cell_type":"code","source":"import cv2\nimport numpy as np\nimport os\nfrom tensorflow.keras.utils import Sequence\n\nprint(\"--- STEP 2: INITIALIZING ENHANCED GENERATORS (3-CHANNEL) ---\")\n\nfinal_train_normal_df = final_train_df[final_train_df['Label'] == 0].reset_index(drop=True)\n\nclass EnhancedAutoencoderGenerator(Sequence):\n    def __init__(self, df, img_col='img_path', vec_cols=None, batch_size=32, target_size=(224, 224), shuffle=True, **kwargs):\n        super().__init__(**kwargs) \n        self.df = df\n        self.img_col = img_col\n        self.vec_cols = vec_cols\n        self.batch_size = batch_size\n        self.target_size = target_size\n        self.shuffle = shuffle\n        self.indices = np.arange(len(self.df))\n        self.base_path = \"/kaggle/input/datasets/tintrancong/ai-powered-musculoskeletal-injury-dataset/Final_Project_TranCongTinCOS1106\"\n        if self.shuffle: np.random.shuffle(self.indices)\n            \n    def __len__(self):\n        return int(np.ceil(len(self.df) / self.batch_size))\n    \n    def on_epoch_end(self):\n        if self.shuffle: np.random.shuffle(self.indices)\n\n    def __getitem__(self, index):\n        batch_indices = self.indices[index * self.batch_size : (index + 1) * self.batch_size]\n        batch_df = self.df.iloc[batch_indices]\n        \n        X_images, X_vectors = [], []\n        for _, row in batch_df.iterrows():\n            img_path = row[self.img_col]\n            full_path = os.path.join(self.base_path, img_path) if not img_path.startswith('/kaggle/input') else img_path\n            \n            img = cv2.imread(full_path)\n            if img is None: continue\n                \n            img_gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY) \n            img_resized = cv2.resize(img_gray, self.target_size)\n            \n            # 1. Kênh