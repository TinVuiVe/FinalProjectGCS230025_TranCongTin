 in range(steps):\n        print(f\"\\rProcessing batch {i+1}/{steps}...\", end=\"\")\n        (X_batch, cond_batch), _ = generator[i]\n        \n        if X_batch.shape[-1] == 1:\n            X_batch = np.repeat(X_batch, 3, axis=-1)\n            \n        batch_features = model.predict(X_batch, verbose=0)\n        features.append(batch_features)\n        \n    print(\" Done!\")\n    return np.vstack(features)\n\nprint(\"\\n--- STEP 3: EXTRACTING TRAINING FEATURES (NORMAL ONLY) ---\")\nX_train_features = extract_features(auto_train_gen, feature_extractor)\nprint(f\"-> Train features shape: {X_train_features.shape}\")\n\nprint(\"\\n--- STEP 4: TRAINING ISOLATION FOREST ---\")\niso_forest = IsolationForest(n_estimators=100, contamination=0.01, random_state=42)\niso_forest.fit(X_train_features)\nprint(\"-> Isolation Forest trained successfully.\")\n\njoblib.dump(iso_forest, 'hybrid_isolation_forest.joblib')\nprint(\"-> SUCCESS: Isolation Forest model saved as 'hybrid_isolation_forest.joblib'\")\n\nprint(\"\\n--- STEP 5: EXTRACTING VALIDATION FEATURES ---\")\nX_valid_features = extract_features(auto_valid_gen, feature_extractor)\n\neval_df = final_valid_df.iloc[:len(X_valid_features)].copy()\ny_true = eval_df['Label'].values\n\nprint(\"\\n--- STEP 6: PREDICTING ANOMALY SCORES & PLOTTING HISTOGRAM ---\")\nanomaly_scores = -iso_forest.decision_function(X_valid_features)\neval_df['Anomaly_Score'] = anomaly_scores\neval_df['Class_Name'] = eval_df['Label'].map({0: 'Normal', 1: 'Abnormal'})\n\nplt.figure(figsize=(10, 6))\nsns.histplot(data=eval_df, x='Anomaly_Score', hue='Class_Name', bins=50, kde=True, \n             palette={'Normal': 'blue', 'Abnormal': 'red'}, alpha=0.6, element=\"step\")\n\nnormal_scores = eval_df[eval_df['Label'] == 0]['Anomaly_Score']\noptimal_threshold = np.percentile(normal_scores, 95)\n\nplt.axvline(optimal_threshold, color='green', linestyle='dashed', linewidth=2, \n            label=f'Chosen Threshold (95th Percentile): {optimal_threshold:.4f}')\