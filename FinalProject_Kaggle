"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 5.13: Optimal Autoencoder Evaluation","metadata":{}},{"cell_type":"code","source":"import numpy as np\nimport pandas as pd\nimport matplotlib.pyplot as plt\nimport seaborn as sns\nfrom sklearn.metrics import roc_curve, auc, classification_report, confusion_matrix, precision_recall_curve\nimport tensorflow as tf\nfrom tensorflow.keras.models import load_model\nimport os\n\nprint(\"--- STEP 1: RECOVERING OPTIMAL MODEL & CALCULATING SSIM LOSS ---\")\n\ndef ssim_loss(y_true, y_pred):\n    return 1.0 - tf.reduce_mean(tf.image.ssim(y_true, y_pred, max_val=1.0))\n\ntry:\n    model_path = 'optimal_autoencoder_best.keras' \n    if not os.path.exists(model_path):\n        model_path = '/kaggle/input/datasets/tintrancong/models-saved/Models/optimal_autoencoder_best.keras'\n    optimal_autoencoder = load_model(model_path, custom_objects={'ssim_loss': ssim_loss})\n    print(f\"-> SUCCESS: Model loaded from {model_path}.\")\nexcept Exception as e:\n    print(f\"-> ERROR loading model: {e}\")\nprint(\"-> Calculating SSIM Error for Validation Set... This might take a minute.\")\nall_losses = []\n\nfor i in range(len(enhanced_valid_gen)):\n    (X_batch, cond_batch), Y_batch = enhanced_valid_gen[i]\n    reconstructions = optimal_autoencoder.predict([X_batch, cond_batch], verbose=0)\n\n    Y_batch_tf = tf.cast(Y_batch, tf.float32)\n    reconstructions_tf = tf.cast(reconstructions, tf.float32)\n    \n    ssim_batch = 1.0 - tf.image.ssim(Y_batch_tf, reconstructions_tf, max_val=1.0)\n    # -----------------------\n    \n    all_losses.extend(ssim_batch.numpy())\n\neval_df = final_valid_df.iloc[:len(all_losses)].copy()\neval_df['Reconstruction_Loss'] = all_losses\n\nprint(\"\\n--- STEP 2: EVALUATING & SAVING METRICS ---\")\n\n# ROC CURVE\nfpr, tpr, thresholds = roc_curve(eval_df['Label'], eval_df['Reconstruction_Loss'])\nroc_auc = auc(fpr, tpr)\n\nplt.figure(figsize=(8, 6))\nplt.plot(fpr, tpr, color='darkorange', lw=2, label=f'ROC (area = {roc_auc:.2f})')\nplt.plot([0, 1], [0, 1], color='navy', lw=2, linestyle='--')\nplt.title('ROC - Optimal Autoencoder (SSIM)')\nplt.xlabel('False Positive Rate')\nplt.ylabel('True Positive Rate')\nplt.legend(loc=\"lower right\")\nplt.savefig('optimal_roc_curve.png')\nplt.show()\n\n# 5. OPTIMAL THRESHOLD \nprecision, recall, pr_thresholds = precision_recall_curve(eval_df['Label'], eval_df['Reconstruction_Loss'])\nf1_scores = 2 * recall * precision / (recall + precision + 1e-10)\noptimal_threshold = pr_thresholds[np.argmax(f1_scores)]\n\nprint(f\"-> Optimal Threshold Found: {optimal_threshold:.6f}\")\neval_df['Predicted_Label'] = (eval_df['Reconstruction_Loss'] > optimal_threshold).astype(int)\n\n# REPORT\nprint(\"\\n--- CLASSIFICATION REPORT ---\")\nprint(classification_report(eval_df['Label'], eval_df['Predicted_Label'], target_names=['Normal', 'Abnormal']))\n\nreport_dict = classification_report(eval_df['Label'], eval_df['Predicted_Label'], target_names=['Normal', 'Abnormal'], output_dict=True)\npd.DataFrame(report_dict).transpose().to_csv('optimal_classification_report.csv', index=True)\n\n# CONFUSION MATRIX\ncm = confusion_matrix(eval_df['Label'], eval_df['Predicted_Label'])\nplt.figure(figsize=(6, 5))\nsns.heatmap(cm, annot=True, fmt='d', cmap='Blues', xticklabels=['Normal', 'Abnormal'], yticklabels=['Normal', 'Abnormal'])\nplt.title('Confusion Matrix - Optimal Autoencoder')\nplt.ylabel('Actual')\nplt.xlabel('Predicted')\nplt.savefig('optimal_confusion_matrix.png')\nplt.show()\n\nprint(\"\\n--- STEP 3: PLOTTING ERROR DISTRIBUTION (NEW & IMPORTANT) ---\")\n\n# ERROR DISTRIBUTION HISTOGRAM \nplt.figure(figsize=(10, 6))\nsns.histplot(eval_df[eval_df['Label'] == 0]['Reconstruction_Loss'], color='blue', label='Normal (Healthy)', kde=True, stat=\"density\", common_norm=False, alpha=0.5)\nsns.histplot(eval_df[eval_df['Label'] == 1]['Reconstruction_Loss'], color='red', label='Abnormal (Fracture/Metal)', kde=True, stat=\"density\", common_norm=False, alpha=0.5)\nplt.axvline(optimal_threshold, color='green', linestyle='--', linewidth=2, label=f'Threshold ({optimal_threshold:.4f})')\nplt.title('Distribution of SSIM Reconstruction Errors')\nplt.xlabel('Reconstruction Error (1 - SSIM)')\nplt.ylabel('Density')\nplt.legend()\nplt.savefig('optimal_error_distribution.png')\nplt.show()\n\nprint(\"\\n--- STEP 4: PLOTTING TRAINING LOSS CURVE ---\")\n\n# LOSS CURVE\nlog_file = 'optimal_training_logs.csv'\nif not os.path.exists(log_file): \n    log_file = '/kaggle/input/datasets/tintrancong/logs-saved/Logs/optimal_training_logs.csv'\n\nif os.path.exists(log_file):\n    history_df = pd.read_csv(log_file)\n    plt.figure(figsize=(10, 6))\n    plt.plot(history_df['epoch'], history_df['loss'], label='Train Loss (SSIM)')\n    plt.plot(history_df['epoch'], history_df['val_loss'], label='Validation Loss (SSIM)')\n    plt.title('Optimal Autoencoder Loss Curve')\n    plt.xlabel('Epoch')\n    plt.ylabel('SSIM Loss')\n    plt.legend()\n    plt.savefig('optimal_loss_curve.png')\n    plt.show()\nelse:\n    print(f\"-> WARNING: Could not find '{log_file}'. Make sure the file name is correct.\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 5.14: Testing","metadata":{}},{"cell_type":"code","source":"import os\nimport cv2\nimport gc\nimport numpy as np\nimport pandas as pd\nimport tensorflow as tf\nfrom tensorflow.keras.models import load_model\nimport matplotlib.pyplot as plt\nimport seaborn as sns\nfrom sklearn.metrics import accuracy_score, roc_curve\n\ndef ssim_loss(y_true, y_pred):\n    return 1.0 - tf.reduce_mean(tf.image.ssim(y_true, y_pred, max_val=1.0))\n\ndef apply_custom_filters(img):\n    gray = cv2.cvtColor(img, cv2.COLOR_RGB2GRAY)\n    gaussian = cv2.GaussianBlur(gray, (5, 5), 0)\n    laplacian = cv2.Laplacian(gaussian, cv2.CV_64F)\n    laplacian = cv2.normalize(laplacian, None, 0, 255, cv2.NORM_MINMAX, dtype=cv2.CV_8U)\n    \n    merged_img = cv2.merge([gray, gaussian, laplacian])\n    return merged_img\n\nmodel_dict_ae = {\n    \"Autoencoder (Baseline)\": \"/kaggle/input/datasets/tintrancong/models-saved/Models/conditional_autoencoder_hyper_best.keras\",\n    \"Autoencoder (Enhanced)\": \"/kaggle/input/datasets/tintrancong/models-saved/Models/enhanced_autoencoder_best.keras\",\n    \"Autoencoder (Optimal)\": \"/kaggle/input/datasets/tintrancong/models-saved/Models/optimal_autoencoder_best.keras\"\n}\n\ndef evaluate_autoencoder(model_path, model_name, df, batch_size=32, target_size=(224, 224)):\n    print(f\"\\n[{model_name}] Đang tải model và tính toán Reconstruction Error...\")\n    \n    model = load_model(model_path, custom_objects={'ssim_loss': ssim_loss})\n    \n    errors = []\n    y_true = df['Label'].values \n    \n    body_parts = ['XR_ELBOW', 'XR_FINGER', 'XR_FOREARM', 'XR_HAND', 'XR_HUMERUS', 'XR_SHOULDER', 'XR_WRIST']\n    vec_cols = [f'prob_{part}' for part in body_parts]\n    \n    for i in range(0, len(df), batch_size):\n        batch_df = df.iloc[i:i+batch_size]\n        X_images = []\n        X_vectors = []\n        \n        for _, row in batch_df.iterrows():\n            img_path = row['img_path']\n            if not img_path.startswith('/kaggle/input'):\n                img_path = os.path.join(\"/kaggle/input/datasets/tintrancong/ai-powered-musculoskeletal-injury-dataset/Final_Project_TranCongTinCOS1106\", img_path)\n                \n            img = cv2.imread(img_path)\n            img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)\n            img = cv2.resize(img, target_size)\n            \n            if \"Baseline\" in model_name:\n                img = cv2.cvtColor(img, cv2.COLOR_RGB2GRAY)\n                img = np.expand_dims(img, axis=-1)\n            else:\n                img = apply_custom_filters(img)\n                \n            img = img.astype(np.float32) / 255.0\n            X_images.append(img)\n            X_vectors.append(row[vec_cols].values.astype(np.float32))\n            \n        X_images = np.array(X_images)\n        X_vectors = np.array(X_vectors)\n        \n        reconstructed = model.predict([X_images, X_vectors], verbose=0)\n        \n        if \"Optimal\" in model_name:\n            ssim_scores = tf.image.ssim(tf.cast(X_images, tf.float32), tf.cast(reconstructed, tf.float32), max_val=1.0).numpy()\n            batch_errors = 1.0 - ssim_scores \n        else:\n            batch_errors = np.mean(np.square(X_images - reconstructed), axis=(1, 2, 3))\n            \n        errors.extend(batch_errors)\n        \n    errors = np.array(errors)\n    avg_error = np.mean(errors)\n    \n    fpr, tpr, thresholds = roc_curve(y_true, errors)\n    optimal_idx = np.argmax(tpr - fpr)\n    best_threshold = thresholds[optimal_idx]\n    \n    y_pred = (errors > best_threshold).astype(int)\n    acc = accuracy_score(y_true, y_pred)\n    \n    print(f\"-> Hoàn tất! Avg Error: {avg_error:.5f} | Best Threshold: {best_threshold:.5f} | Accuracy: {acc:.4f}\")\n    \n    del model\n    tf.keras.backend.clear_session()\n    gc.collect()\n    \n    return {\n        \"Model\": model_name,\n        \"Reconstruction Error\": avg_error,\n        \"Best Threshold\": best_threshold,\n        \"Accuracy\": acc,\n        \"Errors\": errors,\n        \"y_true\": y_true\n    }\n\nresults_list_ae = []\nfor m_name, m_path in model_dict_ae.items():\n    try:\n        res = evaluate_autoencoder(m_path, m_name, final_valid_df) \n        results_list_ae.append(res)\n    except Exception as e:\n        print(f\"-> LỖI khi tải hoặc đánh giá {m_name}: {e}\")\n\nif len(results_list_ae) > 0:\n    report_data = [{k: v for k, v in res.items() if k not in [\"Errors\", \"y_true\"]} for res in results_list_ae]\n    report_df_ae = pd.DataFrame(report_data)\n    report_df_ae.to_csv('/kaggle/working/model2_autoencoder_comparison.csv', index=False)\n    \n    print(\"\\n--- Result for Approach 2 (Autoencoder) ---\")\n    print(report_df_ae.to_string(index=False))\n\n    # 