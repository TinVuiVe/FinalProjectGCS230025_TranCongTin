/input/datasets/tintrancong/gui-tab3/Tab3/plot_densenet121_laplacian_confusion_matrix.png\",\n    \"m1_sobel_curve\": \"/kaggle/input/datasets/tintrancong/gui-tab3/Tab3/plot_densenet121_sobel_learning_curves.png\",\n    \"m1_sobel_cm\": \"/kaggle/input/datasets/tintrancong/gui-tab3/Tab3/plot_densenet121_sobel_confusion_matrix.png\",\n\n    # Model 2 - Supervised\n    \"m2_workflow\": \"/kaggle/input/datasets/tintrancong/gui-tab4/Tab4/Screenshot 2026-04-30 193534.png\",\n    \n    \"m2_supervised_table\": \"/kaggle/input/datasets/tintrancong/gui-tab4/Tab4/model2_comparison_table.png\",\n    \n    \"m2_baseline_curve\": \"/kaggle/input/datasets/tintrancong/gui-tab4/Tab4/training_history_model2_baseline.png\",\n    \"m2_baseline_cm\": \"/kaggle/input/datasets/tintrancong/gui-tab4/Tab4/confusion_matrix_model2_baseline.png\",\n    \n    \"m2_sobel_curve\": \"/kaggle/input/datasets/tintrancong/gui-tab4/Tab4/training_history_model2_DenseNet121_sobel.png\",\n    \"m2_sobel_cm\": \"/kaggle/input/datasets/tintrancong/gui-tab4/Tab4/confusion_matrix_model2_DenseNet121_sobel.png\",\n    \n    \"m2_finetuned_curve\": \"/kaggle/input/datasets/tintrancong/gui-tab4/Tab4/training_history_model2_finetuned.png\",\n    \"m2_finetuned_cm\": \"/kaggle/input/datasets/tintrancong/gui-tab4/Tab4/confusion_matrix_model2_finetuned.png\",\n    \n    \"m2_reg_curve\": \"/kaggle/input/datasets/tintrancong/gui-tab4/Tab4/training_history_model2_reg.png\",\n    \"m2_reg_cm\": \"/kaggle/input/datasets/tintrancong/gui-tab4/Tab4/confusion_matrix_model2_reg.png\",\n    \n    \"m2_final_cm\": \"/kaggle/input/datasets/tintrancong/gui-tab4/Tab4/model2_final_confusion_matrix.png\",\n\n    # Model 2 - Autoencoder\n    \"ae_table\": None,\n    \"ae_curve\": None,\n    \"ae_distribution\": None,\n    \"ae_test_result\": None,\n    \"ae_roc\": None,\n\n    # Exploratory Hybrid\n    \"hybrid_result\": None,\n    \"hybrid_roc\": None,\n\n    # Multi-task\n    \"multitask_table\": None,\n    \"vit_learning_curve\": None,\n    \"vit_cm_14\": None,\n    \"vit_cm_binary\": None,\n}\n\n\n# ============================================================\n# 3. CORE METHODS - DO NOT CHANGE\n# ============================================================\n\ndef apply_sobel(img):\n    if img is None:\n        return None\n    gray = cv2.cvtColor(img, cv2.COLOR_RGB2GRAY)\n    sobelx = cv2.Sobel(gray, cv2.CV_64F, 1, 0, ksize=3)\n    sobely = cv2.Sobel(gray, cv2.CV_64F, 0, 1, ksize=3)\n    sobel_combined = cv2.magnitude(sobelx, sobely)\n    sobel_normalized = cv2.normalize(\n        sobel_combined, None, 0, 255, cv2.NORM_MINMAX, dtype=cv2.CV_8U\n    )\n    return cv2.cvtColor(sobel_normalized, cv2.COLOR_GRAY2RGB)\n\n\ndef triage_image(image):\n    if image is None or not models_loaded:\n        return None, None, None, \"🚫 **Error:** Invalid image or models not loaded.\"\n\n    img_resized = cv2.resize(image, (224, 224))\n\n    # STAGE 1: DENSENET + SOBEL\n    img_sobel = apply_sobel(img_resized)\n    img_input_m1 = img_sobel.astype(np.float32) / 255.0\n    img_input_m1 = np.expand_dims(img_input_m1, axis=0)\n\n    try:\n        preds_m1 = model_1.predict(img_input_m1, verbose=0)[0]\n    except Exception as e:\n        return None, None, None, f\"Model 1 Error: {e}\"\n\n    class_probs_dict_7c = {\n        region: float(prob) for region, prob in zip(anatomical_regions, preds_m1)\n    }\n\n    # STAGE 2: DENSENET REG L2\n    img_input_m2 = preprocess_input(img_resized.astype(np.float32))\n    img_input_m2 = np.expand_dims(img_input_m2, axis=0)\n    cond_vector = np.expand_dims(preds_m1, axis=0)\n\n    try:\n        preds_m2 = model_2.predict([img_input_m2, cond_vector], verbose=0)\n        prob_abnormal = float(preds_m2[0][0])\n        prob_normal = 1.0 - prob_abnormal\n        status = \"Abnormal\" if prob_abnormal >= 0.5 else \"Normal\"\n    except Exception as e:\n        return None, None, None, f\"Model 2 Error: {e}\"\n\n    anomaly_probs_dict = {\n        \"Abnormal\": prob_abnormal,\n        \"Normal\": prob_normal\n    }\n\n    top_region = max(class_probs_dict_7c, key=class_probs_dict_7c.get)\n\n    interpretation = \"### Clinical-style Summary\\n\\n\"\n    interpretation += f\"**Anatomical region:** {top_region}\\n\\n\"\n\n    if status == \"Abnormal\":\n        interpretation += f\"**Triage prediction:** ⚠️ ABNORMAL ({prob_abnormal:.2%})\\n\\n\"\n    else:\n        interpretation += f\"**Triage prediction:** ✅ NORMAL ({prob_normal:.2%})\\n\\n\"\n\n    interpretation += (\n        \"**Note:** This is a research prototype for academic demonstration only. \"\n        \"It is not intended for final clinical diagnosis.\"\n    )\n\n    return class_probs_dict_7c, anomaly_probs_dict, interpretation, img_sobel\n\n\n# ============================================================\n# 4. UI HELPER\n# ============================================================\n\ndef optional_image(path, label, height=360):\n    if path:\n        return gr.Image(value=path, label=label, interactive=False, height=height)\n    return gr.Markdown(\n        f\"\"\"\n        <div class=\"placeholder-box\">\n            <b>{label}</b><br>\n            Image placeholder. Add the corresponding image path in <code>RESULT_IMAGES</code>.\n        </div>\n        \"\"\"\n    )\n\n\n# ============================================================\n# 5. MEDICAL DASHBOARD CSS\n# ============================================================\n\ncustom_css = \"\"\"\nbody, .gradio-container {\n    background: linear-gradient(180deg, #eef7f8 0%, #f8fafc 100%) !important;\n    font-family: Inter, Arial, sans-serif !important;\n}\n\n.header {\n    background: linear-gradient(135deg, #0f766e 0%, #0e7490 100%);\n    color: white !important;\n    padding: 28px;\n    border-radius: 18px;\n    box-shadow: 0 8px 24px rgba(15, 118, 110, 0.25);\n    margin-bottom: 18px;\n}\n\n.header h1, .header p {\n    color: white !important;\n    margin: 0;\n}\n\n.card {\n    background: white !important;\n    border-radius: 18px !important;\n    padding: 20px !important;\n    border: 1px solid #dbeafe !important;\n    box-shadow: 0 4px 14px rgba(15, 23, 42, 0.06) !important;\n}\n\n.metric {\n    background: #ecfeff !important;\n    border-left: 6px solid #0891b2 !important;\n    border-radius: 14px !important;\n    padding: 14px !important;\n    min-height: 95px;\n}\n\n.metric-orange {\n    background: #fff7ed !important;\n    border-left: 6px solid #f97316 !important;\n    border-radius: 14px !important;\n    padding: 14px !important;\n    min-height: 95px;\n}\n\n.metric-red {\n    background: #fef2f2 !important;\n    border-left: 6px solid #dc2626 !important;\n    border-radius: 14px !important;\n    padding: 14px !important;\n    min-height: 95px;\n}\n\n.placeholder-box {\n    padding: 28px;\n    border: 2px dashed #94a3b8;\n    border-radius: 14px;\n    background: #f8fafc;\n    color: #475569;\n    text-align: center;\n    min-height: 140px;\n}\n\n.small {\n    font-size: 13px;\n    color: #64748b;\n}\n\nh2, h3 {\n    color: #0f172a !important;\n}\n\n.gradio-container .tab-nav {\n    background: white !important;\n    border-radius: 14px !important;\n}\n\"\"\"\n\nmedical_theme = gr.themes.Soft(\n    primary_hue=\"teal\",\n    secondary_hue=\"cyan\",\n    neutral_hue=\"slate\"\n).set(\n    button_primary_background_fill=\"#0f766e\",\n    button_primary_background_fill_hover=\"#115e59\",\n    button_primary_text_color=\"white\"\n)\n\n\n# ============================================================\n# 6. DASHBOARD UI\n# ============================================================\n\nwith gr.Blocks(\n    title=\"MSK AI Defense Dashboard\",\n    theme=medical_theme,\n    css=custom_css\n) as demo:\n\n    with gr.Column(elem_classes=\"header\"):\n        gr.Markdown(\"# MSK AI Defense Dashboard\")\n        gr.Markdown(\"AI-Powered Musculoskeletal Injury Triage Using Deep Learning Models\")\n\n    with gr.Tabs():\n\n        # ====================================================\n        # TAB 1: DEFENSE OVERVIEW - UPDATED\n        # ====================================================\n        with gr.Tab(\"1. Overview\"):\n            with gr.Row():\n                with gr.Column(scale=3, elem_classes=\"card\"):\n                    gr.Markdown(\n                        \"\"\"\n                        ## Project Overview\n\n                        This project addresses a key challenge in medical imaging:  \n                        **detecting subtle abnormalities in musculoskeletal X-ray images.**\n\n                        ### Project Tasks\n\n                        **1. Anatomical classification**  \n                        Identify the body region: elbow, finger, forearm, hand, humerus, shoulder, or wrist.\n\n                        **2. Abnormality detection**  \n                        Predict whether the X-ray image is normal or abnormal.\n\n                        ### Main Defense Message\n\n                        Anatomical classification performs strongly because body regions have clearer structural differences.  \n                        Abnormality detection is more challenging because abnormal patterns are subtle and variable.\n                        \"\"\"\n                    )\n\n                with gr.Column(scale=2, elem_classes=\"metric\"):\n                    gr.Markdown(\n                        \"\"\"\n                        ### Final System\n\n                        **Two-stage AI Pipeline**\n\n                        **Stage 1:** Anatomical Classification  \n                        DenseNet121 + Sobel Edge Detection\n\n                        **Stage 2:** Abnormality Detection  \n                        DenseNet121 + L2 Regularization\n\n                        **Final Output:**  \n                        Body region + Normal / Abnormal prediction\n                        \"\"\"\n                    )\n\n            with gr.Row():\n                with gr.Column(elem_classes=\"card\"):\n                    gr.Markdown(\"### Overall System Workflow\")\n                    optional_image(\n                        RESULT_IMAGES[\"overall_pipeline\"],\n                        \"Overall system pipeline: Input X-ray → Model 1 → Model 2 → Output\"\n                    )\n\n        # ====================================================\n        # TAB 2: DATASET AND DATA PROCESSING\n        # ====================================================\n        with gr.Tab(\"2. Dataset\"):\n            gr.Markdown(\"## Dataset Understanding and Preparation\")\n\n            with gr.Row():\n                with gr.Column(scale=1, elem_classes=\"card\"):\n                    gr.Markdown(\n                        \"\"\"\n                        ### Dataset Overview\n\n                        **Dataset:** MURA  \n                        **Modality:** Musculoskeletal X-ray radiographs  \n                        **Classes:** 7 anatomical regions  \n                        **Labels:** Normal / Abnormal  \n\n                        ### Why this dataset is challenging\n\n                        Normal and abnormal X-ray images can look visually similar.  \n                        Abnormal patterns are often subtle, localized, and difficult to separate from normal anatomical structures.\n                        \"\"\"\n                    )\n\n                with gr.Column(scale=2, elem_classes=\"card\"):\n                    gr.Markdown(\"### Visual Examples\")\n                    optional_image(\n                        RESULT_IMAGES[\"data_samples\"],\n                        \"Sample normal and abnormal X-ray images\"\n                    )\n\n            with gr.Row():\n                with gr.Column(scale=1, elem_classes=\"card\"):\n                    gr.Markdown(\n                        \"\"\"\n                        ### Data Preparation Strategy\n\n                        The dataset was prepared carefully to avoid data leakage.\n\n                        **Main steps:**\n\n                        1. Load raw MURA training and validation folders  \n                        2. Split the original training folder into:\n                           - Training set: 80%\n                           - Validation set: 20%\n                        3. Keep the original MURA validation folder as the test set  \n                        4. Apply data augmentation only to the training set  \n                        5. Use validation and test sets only for evaluation\n\n                        ### Defense Point\n\n                        Data augmentation is applied only to the training set.  \n                        This ensures that validation and test results remain fair and unbiased.\n                        \"\"\"\n                    )\n\n                with gr.Column(scale=2, elem_classes=\"card\"):\n                    gr.Markdown(\"### Data Processing Workflow\")\n                    optional_image(\n                        RESULT_IMAGES[\"data_processing_flow\"],\n                        \"Data processing Workflow: raw dataset → train/validation/test split → augmentation only on training set\"\n                    )\n\n            with gr.Row():\n                with gr.Column(elem_classes=\"card\"):\n                    gr.Markdown(\"### Class Distribution\")\n                    optional_image(\n                        RESULT_IMAGES[\"class_distribution\"],\n                        \"Anatomical class distribution\"\n                    )\n\n            with gr.Row():\n                with gr.Column(elem_classes=\"card\"):\n                    gr.Markdown(\n                        \"\"\"\n                        ### Speaking Focus for Defense\n\n                        “Before training the models, I first analyzed and prepared the MURA dataset.  \n                        The original training folder was split into training and validation sets, while the original validation folder was kept separate as the test set.  \n                        Importantly, data augmentation was applied only to the training set to prevent data leakage.”\n                        \"\"\"\n                    )\n\n        # ====================================================\n        # TAB 3: MODEL 1 - ANATOMICAL CLASSIFICATION\n        # ====================================================\n        with gr.Tab(\"3. Model 1 - Anatomical Classification\"):\n            gr.Markdown(\"## Model 1: Anatomical Classification\")\n        \n            with gr.Row():\n                with gr.Column(elem_classes=\"metric\"):\n                    gr.Markdown(\"### Final Model\")\n                    gr.Markdown(\"**DenseNet121 + Sobel**\")\n                with gr.Column(elem_classes=\"metric-orange\"):\n                    gr.Markdown(\"### Accuracy\")\n                    gr.Markdown(\"**97.15%**\")\n                with gr.Column(elem_classes=\"metric\"):\n                    gr.Markdown(\"### Macro F1\")\n                    gr.Markdown(\"**0.9677**\")\n        \n            with gr.Row():\n                with gr.Column(elem_classes=\"card\"):\n                    gr.Markdown(\n                        \"\"\"\n                        ### Model 1 Development Strategy\n        \n                        Model 1 was developed through three experimental stages:\n        \n                        **Stage 1:** Technique optimization  \n                        **Stage 2:** Architecture comparison  \n                        **Stage 3:** Edge detection evaluation  \n        \n                        **Final decision:** DenseNet121 + Sobel was selected because it achieved the strongest and most stable anatomical classification performance.\n                        \"\"\"\n                    )\n        \n            with gr.Row():\n                with gr.Column(elem_classes=\"card\"):\n                    gr.Markdown(\"### Model 1 Workflow\")\n                    optional_image(\n                        RESULT_IMAGES[\"m1_workflow\"],\n                        \"Model 1 workflow: Input X-ray → Sobel enhancement → DenseNet121 → 7 anatomical classes\",\n                        height=420\n                    )\n        \n            # ====================================================\n            # STAGE 1\n            # ====================================================\n            with gr.Accordion(\"Stage 1: Technique Optimization\", open=True):\n                with gr.Row():\n                    with gr.Column(scale=1, elem_classes=\"card\"):\n                        gr.Markdown(\n                            \"\"\"\n                            ### Purpose\n        \n                            Compare different training strategies:\n        \n                            - Baseline  \n                            - Fine-tuning  \n                            - Fine-tuning + class weighting  \n                            - Fine-tuning + augmentation  \n                            - Combined strategy  \n        \n                            ### Key Insight\n        \n                            Fine-tuning improves performance clearly, while the combined strategy provides a more complete optimization setting.\n                            \"\"\"\n                        )\n                    with gr.Column(scale=2, elem_classes=\"card\"):\n                        optional_image(\n                            RESULT_IMAGES[\"m1_stage1_table\"],\n                            \"Stage 1 comparison table\",\n                            height=300\n                        )\n        \n                with gr.Accordion(\"Detailed Outputs: Stage 1 Models\", open=False):\n        \n                    with gr.Accordion(\"Baseline Model\", open=False):\n                        with gr.Row():\n                            with gr.Column(elem_classes=\"card\"):\n                                optional_image(\n                                    RESULT_IMAGES[\"m1_baseline_curve\"],\n                                    \"Baseline learning curve\",\n                                    height=330\n                                )\n                            with gr.Column(elem_classes=\"card\"):\n                                optional_image(\n                                    RESULT_IMAGES[\"m1_baseline_cm\"],\n                                    \"Baseline confusion matrix\",\n                                    height=330\n                                )\n\n                    \n                    with gr.Accordion(\"Fine-tuned Model\", open=False):\n                        with gr.Row():\n                            with gr.Column(elem_classes=\"card\"):\n                                optional_image(\n                                    RESULT_IMAGES[\"m1_finetune_curve\"],\n                                    \"Fine-tuning learning curve\",\n                                    height=330\n                                )\n                            with gr.Column(elem_classes=\"card\"):\n                                optional_image(\n                                    RESULT_IMAGES[\"m1_finetune_cm\"],\n                                    \"Fine-tuning confusion matrix\",\n                                    height=330\n                                )\n        \n                    with gr.Accordion(\"Fine-tuning + Class Weight\", open=False):\n                        with gr.Row():\n                            with gr.Column(elem_classes=\"card\"):\n                                optional_image(\n                                    RESULT_IMAGES[\"m1_ft_cw_curve\"],\n                                    \"Fine-tuning + class weight learning curve\",\n                                    height=330\n                                )\n                            with gr.Column(elem_classes=\"card\"):\n                                optional_image(\n                                    RESULT_IMAGES[\"m1_ft_cw_cm\"],\n                                    \"Fine-tuning + class weight confusion matrix\",\n                                    height=330\n                                )\n        \n                    with gr.Accordion(\"Fine-tuning + Augmentation\", open=False):\n                        with gr.Row():\n                            with gr.Column(elem_classes=\"card\"):\n                                optional_image(\n                                    RESULT_IMAGES[\"m1_ft_aug_curve\"],\n                                    \"Fine-tuning + augmentation learning curve\",\n                                    height=330\n                                )\n                            with gr.Column(elem_classes=\"card\"):\n                                optional_image(\n                                    RESULT_IMAGES[\"m1_ft_aug_cm\"],\n                                    \"Fine-tuning + augmentation confusion matrix\",\n                                    height=330\n                                )\n        \n                    with gr.Accordion(\"Combined Strategy\", open=False):\n                        with gr.Row():\n                            with gr.Column(elem_classes=\"card\"):\n                                optional_image(\n                                    RESULT_IMAGES[\"m1_combined_curve\"],\n                                    \"Combined strategy learning curve\",\n                                    height=330\n                                )\n                            with gr.Column(elem_classes=\"card\"):\n                                optional_image(\n                                    RESULT_IMAGES[\"m1_combined_cm\"],\n                                    \"Combined strategy confusion matrix\",\n                                    height=330\n                                )\n        \n            # ====================================================\n            # STAGE 2\n            # ====================================================\n            with gr.Accordion(\"Stage 2: Model Architecture Comparison\", open=False):\n                with gr.Row():\n                    with gr.Column(scale=1, elem_classes=\"card\"):\n                        gr.Markdown(\n                            \"\"\"\n                            ### Purpose\n        \n                            Compare different CNN architectures:\n        \n                            - Basic CNN  \n                            - DenseNet121  \n                            - ResNet50  \n                            - EfficientNetB0  \n        \n                            ### Key Insight\n        \n                            DenseNet121 performs best because dense connections support feature reuse and stable gradient flow.\n                            \"\"\"\n                        )\n                    with gr.Column(scale=2, elem_classes=\"card\"):\n                        optional_image(\n                            RESULT_IMAGES[\"m1_stage2_table\"],\n                            \"Stage 2 architecture comparison table\",\n                            height=300\n                        )\n        \n                with gr.Accordion(\"Detailed Outputs: Architecture Models\", open=False):\n        \n                    with gr.Accordion(\"Basic CNN\", open=False):\n                        with gr.Row():\n                            with gr.Column(elem_classes=\"card\"):\n                                optional_image(\n                                    RESULT_IMAGES[\"m1_basiccnn_curve\"],\n                                    \"Basic CNN learning curve\",\n                                    height=330\n                                )\n                            with gr.Column(elem_classes=\"card\"):\n                                optional_image(\n                                    RESULT_IMAGES[\"m1_basiccnn_cm\"],\n                                    \"Basic CNN confusion matrix\",\n                                    height=330\n                                )\n        \n                    with gr.Accordion(\"DenseNet121\", open=False):\n                        with gr.Row():\n                            with gr.Column(elem_classes=\"card\"):\n                                optional_image(\n                                    RESULT_IMAGES[\"m1_densenet_curve\"],\n                                    \"DenseNet121 learning curve\",\n                                    height=330\n                                )\n                            with gr.Column(elem_classes=\"card\"):\n                                optional_image(\n                                    RESULT_IMAGES[\"m1_densenet_cm\"],\n                                    \"DenseNet121 confusion matrix\",\n                                    height=330\n                                )\n        \n                    with gr.Accordion(\"ResNet50\", open=False):\n                        with gr.Row():\n                            with gr.Column(elem_classes=\"card\"):\n                                optional_image(\n                                    RESULT_IMAGES[\"m1_resnet_curve\"],\n                                    \"ResNet50 learning curve\",\n                                    height=330\n                                )\n                            with gr.Column(elem_classes=\"card\"):\n                                optional_image(\n                                    RESULT_IMAGES[\"m1_resnet_cm\"],\n                                    \"ResNet50 confusion matrix\",\n                                    height=330\n                                )\n        \n                    with gr.Accordion(\"EfficientNetB0\", open=False):\n                        with gr.Row():\n                            with gr.Column(elem_classes=\"card\"):\n                                optional_image(\n                                    RESULT_IMAGES[\"m1_efficientnet_curve\"],\n                                    \"EfficientNetB0 learning curve\",\n                                    height=330\n                                )\n                            with gr.Column(elem_classes=\"card\"):\n                                optional_image(\n                                    RESULT_IMAGES[\"m1_efficientnet_cm\"],\n                                    \"EfficientNetB0 confusion matrix\",\n                                    height=330\n                                )\n        \n            # ====================================================\n            # STAGE 3\n            # ====================================================\n            with gr.Accordion(\"Stage 3: Edge Detection Evaluation\", open=False):\n                with gr.Row():\n                    with gr.Column(scale=1, elem_classes=\"card\"):\n                        gr.Markdown(\n                            \"\"\"\n                            ### Purpose\n        \n                            Evaluate spatial-domain edge filters:\n        \n                            - Canny  \n                            - Laplacian  \n                            - Sobel  \n        \n                            ### Key Insight\n        \n                            Sobel provides the best result because anatomical classification benefits from clear bone boundaries and structural edges.\n                            \"\"\"\n                        )\n                    with gr.Column(scale=2, elem_classes=\"card\"):\n                        optional_image(\n                            RESULT_IMAGES[\"m1_stage3_table\"],\n                            \"Stage 3 edge detection comparison table\",\n                            height=300\n                        )\n        \n                with gr.Accordion(\"Detailed Outputs: Edge Detection Models\", open=False):\n        \n                    with gr.Accordion(\"DenseNet121 + Canny\", open=False):\n                        with gr.Row():\n                            with gr.Column(elem_classes=\"card\"):\n                                optional_image(\n                                    RESULT_IMAGES[\"m1_canny_curve\"],\n                                    \"DenseNet121 + Canny learning curve\",\n                                    height=330\n                                )\n                            with gr.Column(elem_classes=\"card\"):\n                                optional_image(\n                                    RESULT_IMAGES[\"m1_canny_cm\"],\n                                    \"DenseNet121 + Canny confusion matrix\",\n                                    height=330\n                                )\n        \n                    with gr.Accordion(\"DenseNet121 + Laplacian\", open=False):\n                        with gr.Row():\n                            with gr.Column(elem_classes=\"card\"):\n                                optional_image(\n                                    RESULT_IMAGES[\"m1_laplacian_curve\"],\n                                    \"DenseNet121 + Laplacian learning curve\",\n                                    height=330\n                                )\n                            with gr.Column(elem_classes=\"card\"):\n                                optional_image(\n                                    RESULT_IMAGES[\"m1_laplacian_cm\"],\n                                    \"DenseNet121 + Laplacian confusion matrix\",\n                                    height=330\n                                )\n        \n                    with gr.Accordion(\"DenseNet121 + Sobel\", open=True):\n                        with gr.Row():\n                            with gr.Column(elem_classes=\"card\"):\n                                optional_image(\n                                    RESULT_IMAGES[\"m1_sobel_curve\"],\n                                    \"DenseNet121 + Sobel learning curve\",\n                                    height=330\n                                )\n                            with gr.Column(elem_classes=\"card\"):\n                                optional_image(\n                                    RESULT_IMAGES[\"m1_sobel_cm\"],\n                                    \"DenseNet121 + Sobel confusion matrix\",\n                                    height=330\n                                )\n\n                    with gr.Accordion(\"Final Model 1 Evaluation on Test Set\", open=True):\n                        with gr.Row():\n                            with gr.Column(elem_classes=\"card\"):\n                                optional_image(\n                                    RESULT_IMAGES[\"m1_final_cm\"],\n                                    \"Final Model 1 confusion matrix on test set\",\n                                    height=330\n                                )\n                         \n                    \n            # ====================================================\n            # FINAL DEFENSE SUMMARY\n            # ====================================================\n            with gr.Row():\n                with gr.Column(elem_classes=\"card\"):\n                    gr.Markdown(\n                        \"\"\"\n                        ### Final Defense Summary\n        \n                        The final Model 1 configuration is **DenseNet121 + Sobel**.  \n                        It achieves high performance because anatomical regions contain strong structural differences, and Sobel edge enhancement helps emphasize bone boundaries.\n        \n                        **Main limitation:** some confusion may still occur between visually similar anatomical regions.\n                        \"\"\"\n                    )\n\n        # ====================================================\n        # TAB 4: MODEL 2 - SUPERVISED\n        # ====================================================\n        with gr.Tab(\"4. Model 2 - Supervised Classification\"):\n            gr.Markdown(\"## Model 2: Approach 1 - Supervised Classification\")\n        \n            with gr.Row():\n                with gr.Column(elem_classes=\"metric\"):\n                    gr.Markdown(\"### Best Method\")\n                    gr.Markdown(\"**DenseNet121 + L2 Regularization**\")\n                with gr.Column(elem_classes=\"metric-orange\"):\n                    gr.Markdown(\"### Test Accuracy\")\n                    gr.Markdown(\"**76–77% on test set**\")\n                with gr.Column(elem_classes=\"metric-red\"):\n                    gr.Markdown(\"### Key Issue\")\n                    gr.Markdown(\"**False negatives**\")\n        \n            with gr.Row():\n                with gr.Column(elem_classes=\"card\"):\n                    gr.Markdown(\n                        \"\"\"\n                        ### Model 2 Development Strategy\n        \n                        Model 2 was developed to detect whether an X-ray image is **normal or abnormal**.\n        \n                        The supervised approach compares several DenseNet121-based configurations:\n        \n                        **1. Baseline model**  \n                        **2. DenseNet121 + Sobel**  \n                        **3. Fine-tuned DenseNet121**  \n                        **4. DenseNet121 + L2 Regularization**\n        \n                        **Final decision:** DenseNet121 + L2 Regularization was selected because it achieved the best and most stable supervised abnormality detection performance.\n                        \"\"\"\n                    )\n        \n            with gr.Row():\n                with gr.Column(elem_classes=\"card\"):\n                    gr.Markdown(\"### Model 2 Workflow\")\n                    optional_image(\n                        RESULT_IMAGES[\"m2_workflow\"],\n                        \"Model 2 workflow: Input X-ray + Model 1 anatomical output → DenseNet121 + L2 → Normal / Abnormal\",\n                        height=420\n                    )\n        \n            gr.Markdown(\n                \"\"\"\n                ### Defense Point\n        \n                Supervised abnormality detection is more difficult than anatomical classification because abnormal patterns are often subtle, localized, and visually close to normal anatomical structures.\n        \n                Although DenseNet121 + L2 Regularization is the best supervised model in this project, false negatives remain the key limitation.\n                \"\"\"\n            )\n        \n            # ====================================================\n            # MODEL 2 COMPARISON TABLE\n            # ====================================================\n            with gr.Accordion(\"Model 2 Experiment Comparison\", open=True):\n                with gr.Row():\n                    with gr.Column(elem_classes=\"card\"):\n                        optional_image(\n                            RESULT_IMAGES[\"m2_supervised_table\"],\n                            \"Model 2 supervised classification comparison table\",\n                            height=360\n                        )\n        \n            # ====================================================\n            # BASELINE MODEL\n            # ====================================================\n            with gr.Accordion(\"Detailed Output 1: Baseline Model\", open=False):\n                with gr.Row():\n                    with gr.Column(elem_classes=\"card\"):\n                        optional_image(\n                            RESULT_IMAGES[\"m2_baseline_curve\"],\n                            \"Baseline model training curve\",\n                            height=330\n                        )\n                    with gr.Column(elem_classes=\"card\"):\n                        optional_image(\n                            RESULT_IMAGES[\"m2_baseline_cm\"],\n                            \"Baseline model confusion matrix\",\n                            height=330\n                        )\n        \n            # ====================================================\n            # DENSENET121 + SOBEL\n            # ====================================================\n            with gr.Accordion(\"Detailed Output 2: DenseNet121 + Sobel\", open=False):\n                with gr.Row():\n                    with gr.Column(elem_classes=\"card\"):\n                        optional_image(\n                            RESULT_IMAGES[\"m2_sobel_curve\"],\n                            \"DenseNet121 + Sobel training curve\",\n                            height=330\n                        )\n                    with gr.Column(elem_classes=\"card\"):\n                        optional_image(\n                            RESULT_IMAGES[\"m2_sobel_cm\"],\n                            \"DenseNet121 + Sobel confusion matrix\",\n                            height=330\n                        )\n        \n            # ====================================================\n            # FINE-TUNED DENSENET121\n            # ====================================================\n            with gr.Accordion(\"Detailed Output 3: Fine-tuned DenseNet121\", open=False):\n                with gr.Row():\n                    with gr.Column(elem_classes=\"card\"):\n                        optional_image(\n                            RESULT_IMAGES[\"m2_finetuned_curve\"],\n                            \"Fine-tuned DenseNet121 training curve\",\n                            height=330\n                        )\n                    with gr.Column(elem_classes=\"card\"):\n                        optional_image(\n                            RESULT_IMAGES[\"m2_finetuned_cm\"],\n                            \"Fine-tuned DenseNet121 confusion matrix\",\n                            height=330\n                        )\n        \n            # ====================================================\n            # DENSENET121 + L2 REGULARIZATION\n            # ====================================================\n            with gr.Accordion(\"Detailed Output 4: DenseNet121 + L2 Regularization\", open=True):\n                with gr.Row():\n                    with gr.Column(elem_classes=\"card\"):\n                        optional_image(\n                            RESULT_IMAGES[\"m2_reg_curve\"],\n                            \"DenseNet121 + L2 Regularization training curve\",\n                            height=330\n                        )\n                    with gr.Column(elem_classes=\"card\"):\n                        optional_image(\n                            RESULT_IMAGES[\"m2_reg_cm\"],\n                            \"DenseNet121 + L2 Regularization confusion matrix\",\n                            height=330\n                        )\n        \n            # ====================================================\n            # FINAL CONFUSION MATRIX\n            # ====================================================\n            with gr.Accordion(\"Final Model 2 Evaluation on Test Set\", open=True):\n                with gr.Row():\n                    with gr.Column(elem_classes=\"card\"):\n                        optional_image(\n                            RESULT_IMAGES[\"m2_final_cm\"],\n                            \"Final Model 2 confusion matrix on test set\",\n                            height=420\n                        )\n        \n            # ====================================================\n            # FINAL DEFENSE SUMMARY\n            # ====================================================\n            with gr.Row():\n                with gr.Column(elem_classes=\"card\"):\n                    gr.Markdown(\n                        \"\"\"\n                        ### Final Defense Summary\n        \n                        The final supervised abnormality detection model is **DenseNet121 + L2 Regularization**.\n        \n                        Compared with anatomical classification, abnormality detection is more challenging because abnormal features are not always visually obvious.  \n                        Some abnormal cases may look very similar to normal X-rays, which leads to false negatives.\n        \n                        Therefore, this model is suitable for academic triage demonstration, but it should not be used as a standalone clinical diagnostic system.\n                        \"\"\"\n                    )\n\n        # ====================================================\n        # TAB 5: MODEL 2 - AUTOENCODER\n        # ====================================================\n        with gr.Tab(\"5. Model 2 - Autoencoder\"):\n            gr.Markdown(\"## Model 2: Approach 2 - Autoencoder-Based Anomaly Detection\")\n\n            with gr.Row():\n                with gr.Column(elem_classes=\"metric\"):\n                    gr.Markdown(\"### Best Autoencoder\")\n                    gr.Markdown(\"**Baseline Autoencoder**\")\n                with gr.Column(elem_classes=\"metric-red\"):\n                    gr.Markdown(\"### Result\")\n                    gr.Markdown(\"**Poor separation**\")\n                with gr.Column(elem_classes=\"metric-red\"):\n                    gr.Markdown(\"### Main Cause\")\n                    gr.Markdown(\"**Error overlap**\")\n\n            gr.Markdown(\n                \"\"\"\n                ### Defense Point\n\n                Autoencoder anomaly detection fails because normal and abnormal reconstruction errors overlap strongly.\n                \"\"\"\n            )\n\n            with gr.Row():\n                with gr.Column(elem_classes=\"card\"):\n                    optional_image(\n                        RESULT_IMAGES[\"ae_table\"],\n                        \"Place autoencoder comparison table here\"\n                    )\n                with gr.Column(elem_classes=\"card\"):\n                    optional_image(\n                        RESULT_IMAGES[\"ae_curve\"],\n                        \"Place autoencoder training loss curve here\"\n                    )\n\n            with gr.Row():\n                with gr.Column(elem_classes=\"card\"):\n                    optional_image(\n                        RESULT_IMAGES[\"ae_distribution\"],\n                        \"Place reconstruction error distribution here\"\n                    )\n                with gr.Column(elem_classes=\"card\"):\n                    optional_image(\n                        RESULT_IMAGES[\"ae_roc\"],\n                        \"Place autoencoder ROC curve here\"\n                    )\n\n            with gr.Row():\n                with gr.Column(elem_classes=\"card\"):\n                    optional_image(\n                        RESULT_IMAGES[\"ae_test_result\"],\n                        \"Place autoencoder test evaluation/confusion matrix here\"\n                    )\n\n        # ====================================================\n        # TAB 6: EXPLORATORY APPROACHES\n        # ====================================================\n        with gr.Tab(\"6. Exploratory Approaches\"):\n            gr.Markdown(\"## Exploratory and Alternative Approaches\")\n\n            with gr.Accordion(\"Feature-based Method: DenseNet121 + Isolation Forest\", open=True):\n                gr.Markdown(\n                    \"\"\"\n                    **Purpose:** Test whether deep features can be used for anomaly detection.\n\n                    **Result:** Near-random performance.\n\n                    **Defense point:** Features learned for anatomical classification are not suitable for unsupervised abnormality detection.\n                    \"\"\"\n                )\n                with gr.Row():\n                    with gr.Column(elem_classes=\"card\"):\n                        optional_image(\n                            RESULT_IMAGES[\"hybrid_result\"],\n                            \"Place hybrid anomaly score distribution and confusion matrix here\"\n                        )\n                    with gr.Column(elem_classes=\"card\"):\n                        optional_image(\n                            RESULT_IMAGES[\"hybrid_roc\"],\n                            \"Place hybrid ROC curve here\"\n                        )\n\n            with gr.Accordion(\"Alternative Approach: Multi-task Learning\", open=True):\n                gr.Markdown(\n                    \"\"\"\n                    **Purpose:** Predict anatomical class and abnormality using one model.\n\n                    **Best model:** Vision Transformer.\n\n                    **Defense point:** Multi-task learning is promising but struggles to balance both objectives.\n                    \"\"\"\n                )\n                with gr.Row():\n                    with gr.Column(elem_classes=\"card\"):\n                        optional_image(\n                            RESULT_IMAGES[\"multitask_table\"],\n                            \"Place multi-task model comparison table here\"\n                        )\n                    with gr.Column(elem_classes=\"card\"):\n                        optional_image(\n                            RESULT_IMAGES[\"vit_learning_curve\"],\n                            \"Place ViT learning curve here\"\n                        )\n                with gr.Row():\n                    with gr.Column(elem_classes=\"card\"):\n                        optional_image(\n                            RESULT_IMAGES[\"vit_cm_14\"],\n                            \"Place ViT 14-class confusion matrix here\"\n                        )\n                    with gr.Column(elem_classes=\"card\"):\n                        optional_image(\n                            RESULT_IMAGES[\"vit_cm_binary\"],\n                            \"Place ViT binary confusion matrix here\"\n                        )\n\n        # ====================================================\n        # TAB 7: FINAL COMPARISON\n        # ====================================================\n        with gr.Tab(\"7. Final Comparison\"):\n            gr.Markdown(\"## Final Comparison and Decision\")\n\n            gr.Markdown(\n                \"\"\"\n                | Component | Best Configuration | Main Result | Final Decision |\n                |---|---|---|---|\n                | Model 1 | DenseNet121 + Sobel | 97.15% accuracy | Selected |\n                | Model 2 - Supervised | DenseNet121 + L2 | 76–77% accuracy | Selected |\n                | Autoencoder | Baseline AE | Poor separation | Not selected |\n                | Feature-based | DenseNet + Isolation Forest | AUC ≈ 0.49 | Not selected |\n                | Multi-task | ViT | 71.26% accuracy | Not selected |\n\n                ### Final Product\n\n                The final dashboard uses the **two-stage supervised pipeline**:\n\n                **Input X-ray → DenseNet121 + Sobel → Anatomical region → DenseNet121 + L2 → Normal/Abnormal**\n                \"\"\"\n            )\n\n        # ====================================================\n        # TAB 8: LIVE DEMO\n        # ====================================================\n        with gr.Tab(\"8. Live Demo\"):\n            gr.Markdown(\"## Live Product Demonstration\")\n\n            with gr.Row():\n                with gr.Column(scale=1, elem_classes=\"card\"):\n                    gr.Markdown(\n                        \"\"\"\n                        ### System Parameters\n\n                        **Stage 1:** DenseNet121 + Sobel  \n                        **Stage 2:** DenseNet121 + L2 Regularization  \n                        **Threshold:** 0.5  \n                        **Purpose:** Research triage demo\n                        \"\"\"\n                    )\n\n                    with gr.Accordion(\"Developer View: Sobel Image\", open=False):\n                        debug_sobel_img = gr.Image(label=\"Sobel Edge Map\", interactive=False)\n\n                with gr.Column(scale=3):\n                    with gr.Row(elem_classes=\"card\"):\n                        with gr.Column():\n                            input_img = gr.Image(\n                                label=\"Upload X-ray Image\",\n                                type=\"numpy\"\n                            )\n                            submit_btn = gr.Button(\"Run AI Analysis\", variant=\"primary\")\n\n                        with gr.Column():\n                            output_class_label = gr.Label(\n                                label=\"Stage 1: Anatomical Probabilities\",\n                                num_top_classes=3\n                            )\n                            output_anomaly_label = gr.Label(\n                                label=\"Stage 2: Abnormality Confidence\",\n                                num_top_classes=2\n                            )\n\n                    with gr.Row(elem_classes=\"card\"):\n                        output_text = gr.Markdown(label=\"Automated Report\")\n\n            submit_btn.click(\n                fn=triage_image,\n                inputs=input_img,\n                outputs=[\n                    output_class_label,\n                    output_anomaly_label,\n                    output_text,\n                    debug_sobel_img\n                ]\n            )\n\n        # ====================================================\n        # TAB 9: LIMITATIONS\n        # ====================================================\n        with gr.Tab(\"9. Limitations & Future Work\"):\n            gr.Markdown(\n                \"\"\"\n                ## Limitations\n\n                - Abnormality detection remains limited due to subtle pathological patterns.\n                - False negatives are a critical issue in medical applications.\n                - The system is evaluated on the MURA dataset only.\n                - The dashboard is a research prototype, not a clinical diagnostic tool.\n\n                ## Future Work\n\n                - Use larger and more diverse datasets.\n                - Apply self-supervised or contrastive learning.\n                - Improve multi-task learning with loss balancing.\n                - Add explainability methods such as Grad-CAM.\n                - Validate the system with medical experts.\n                \"\"\"\n            )\n\n    gr.Markdown(\n        \"\"\"\n        <br>\n        <center>\n        <small>\n        This dashboard is for academic defense and research demonstration only. \n        It is not intended for final clinical diagnosis.\n        </small>\n        </center>\n        \"\"\"\n    )\n\ndemo.launch(share=True, debug=True)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-30T20:56:30.782972Z","iopub.execute_input":"2026-04-30T20:56:30.783305Z","iopub.status.idle":"2026-04-30T20:58:36.337815Z","shell.execute_reply.started":"2026-04-30T20:56:30.783264Z","shell.execute_reply":"2026-04-30T20:58:36.33674Z"}},"outputs":[{"name":"stdout","text":"--- INITIALIZING MSK DEFENSE DASHBOARD ---\n-> Loading models...\n-> Models loaded successfully.\n","output_type":"stream"},{"name":"stderr","text":"/tmp/ipykernel_57/759506947.py:305: DeprecationWarning: The 'theme' parameter in the Blocks constructor will be removed in Gradio 6.0. You will need to pass 'theme' to Blocks.launch() instead.\n  with gr.Blocks(\n/tmp/ipykernel_57/759506947.py:305: DeprecationWarning: The 'css' parameter in the Blocks constructor will be removed in Gradio 6.0. You will need to pass 'css' to Blocks.launch() instead.\n  with gr.Blocks(\n","output_type":"stream"},{"name":"stdout","text":"* Running on local URL:  http://127.0.0.1:7861\n* Running on public URL: https://75124ddebca523c620.gradio.live\n\nThis share link expires in 1 week. For free permanent hosting and GPU upgrades, run `gradio deploy` from the terminal in the working directory to deploy to Hugging Face Spaces (https://huggingface.co/spaces)\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<IPython.core.display.HTML object>","text/html":"<div><iframe src=\"https://75124ddebca523c620.gradio.live\" wi