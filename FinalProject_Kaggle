, \n    model_path='/kaggle/input/datasets/tintrancong/models-saved/Models/model_basic_cnn.keras', \n    log_path='/kaggle/input/datasets/tintrancong/logs-saved/Logs/log_basic_cnn.csv', \n    prefix_name='basic_cnn'\n)","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 14.1 Comparison","metadata":{}},{"cell_type":"code","source":"import os\nimport gc\nimport cv2\nimport numpy as np\nimport pandas as pd\nimport tensorflow as tf\nfrom tensorflow.keras.models import load_model\nimport matplotlib.pyplot as plt\nfrom sklearn.metrics import accuracy_score, precision_score, recall_score, f1_score\n\nfrom tensorflow.keras.applications.mobilenet_v2 import preprocess_input\n\nprint(\"--- Start Evaluating (MODEL 1 - STAGE 2: FIXED PREPROCESSING) ---\")\n\nmodel_dict_stage2 = {\n    \"Basic CNN\": \"/kaggle/input/datasets/tintrancong/models-saved/Models/model_basic_cnn.keras\",\n    \"DenseNet121\": \"/kaggle/input/datasets/tintrancong/models-saved/Models/model_densenet121.keras\",\n    \"ResNet50\": \"/kaggle/input/datasets/tintrancong/models-saved/Models/model_resnet50.keras\",\n    \"EfficientNetB0\": \"/kaggle/input/datasets/tintrancong/models-saved/Models/model_efficientnetb0.keras\"\n}\n\nprint(\"\\nWaiting... Nạp và tiền xử lý ảnh\")\nX_eval_s2 = []\ny_true_s2 = final_valid_df['label_idx'].values \nTARGET_SIZE = (224, 224)\n\nfor index, row in final_valid_df.iterrows():\n    img_path = row['img_path'] \n    \n    img = cv2.imread(img_path)\n    if img is None:\n        img = np.zeros((*TARGET_SIZE, 3), dtype=np.float32)\n    else:\n        img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)\n        img = cv2.resize(img, TARGET_SIZE)\n        \n    img = preprocess_input(img.astype(np.float32))\n    X_eval_s2.append(img)\n\nX_eval_s2 = np.array(X_eval_s2)\nprint(f\"-> Nạp xong! Kích thước mảng X_eval_s2: {X_eval_s2.shape}\")\n\nresults_list_s2 = []\n\nfor model_name, model_path in model_dict_stage2.items():\n    print(f\"\\