           img = cv2.imread(full_path)\n            if img is None: continue\n                \n            img_gray = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY) \n            img_resized = cv2.resize(img_gray, self.target_size)\n            \n            # 1. Kênh 1: Original\n            orig_ch = img_resized.astype(np.float32) / 255.0\n            # 2. Kênh 2: Low-pass (Blur)\n            low_ch = cv2.GaussianBlur(img_resized, (5, 5), 0).astype(np.float32) / 255.0\n            # 3. Kênh 3: High-pass (Laplacian Edges)\n            high_pass = cv2.Laplacian(img_resized, cv2.CV_64F)\n            high_pass = np.absolute(high_pass)\n            high_ch = (high_pass / np.max(high_pass)) if np.max(high_pass) > 0 else high_pass.astype(np.float32)\n            \n            img_3ch = np.stack([orig_ch, low_ch, high_ch], axis=-1)\n            X_images.append(img_3ch)\n            \n            if self.vec_cols:\n                X_vectors.append(row[self.vec_cols].values.astype(np.float32))\n                \n        X_images = np.array(X_images)\n        if self.vec_cols:\n            X_vectors = np.array(X_vectors)\n            return (X_images, X_vectors), X_images \n        return X_images, X_images\n        \nenhanced_train_gen = EnhancedAutoencoderGenerator(final_train_normal_df, vec_cols=softmax_columns, batch_size=32, shuffle=True)\nenhanced_valid_gen = EnhancedAutoencoderGenerator(final_valid_df, vec_cols=softmax_columns, batch_size=32, shuffle=False)\nenhanced_test_gen = EnhancedAutoencoderGenerator(test_df, vec_cols=softmax_columns, batch_size=32, shuffle=False)\n\nprint(\"Done\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 5.8: Hyperparameter Tuning for Enhanced Autoencoder","metadata":{}},{"cell_type":"code","source":"import keras_tuner as kt\nfrom tensorflow.keras.layers import Input, Conv2D, Flatten, Dense, Reshape, Conv2DTranspose, Concatenate, BatchNormalization, LeakyReLU\nfrom tensorflow.keras.models import Model\nfrom tensorflow.keras.optimizers import Adam\nimport numpy as np\n\n\ndef build_enhanced_model(hp):\n    latent_dim = hp.Choice('latent_dim', values=[256, 512])\n    \n    # Input 3 kênh (Gốc, Low, High)\n    input_img = Input(shape=(224, 224, 3), name='enhanced_image_input')\n    \n    # Encoder deeper\n    x = Conv2D(32, (3, 3), padding='same', strides=2)(input_img)\n    x = LeakyReLU(alpha=0.2)(x)\n    \n    x = Conv2D(64, (3, 3), padding='same', strides=2)(x)\n    x = BatchNormalization()(x)\n    x = LeakyReLU(alpha=0.2)(x)\n    \n    x = Conv2D(128, (3, 3), padding='same', strides=2)(x)\n    x = BatchNormalization()(x)\n    x = LeakyReLU(alpha=0.2)(x)\n    \n    x = Conv2D(256, (3, 3), padding='same', strides=2)(x) # Lớp local pattern mới\n    x = BatchNormalization()(x)\n    x = LeakyReLU(alpha=0.2)(x)\n    \n    enc_shape = x.shape[1:] \n    x = Flatten()(x)            \n    latent_vec = Dense(latent_dim, activation='relu')(x)\n\n    # Bottleneck\n    input_cond = Input(shape=(7,), name='condition_input')\n    merged = Concatenate()([latent_vec, input_cond])\n\n    # Decoder\n    x = Dense(np.prod(enc_shape), activation='relu')(merged)\n    x = Reshape(enc_shape)(x)\n    \n    for filters in [256, 128, 64, 32]:\n        x = Conv2DTranspose(filters, (3, 3), padding='same', strides=2)(x)\n        if filters != 32: x = BatchNormalization()(x)\n        x = LeakyReLU(alpha=0.2)(x)\n    \n    output_img = Conv2DTranspose(3, (3, 3), activation='sigmoid', padding='same')(x)\n\n    model = Model(inputs=[input_img, input_cond], outputs=output_img)\n    lr = hp.Choice('learning_rate', values=[1e-3, 1e-4, 1e-5])\n    model.compile(optimizer=Adam(learning_rate=lr), loss='mse')\n    return model\n\nenhanced_tuner = kt.RandomSearch(\n    build_enhanced_model,\n    objective='val_loss',\n    max_trials=3,\n    directory='enhanced_autoencoder_tuning', # Tên thư mục mới\n    project_name='enhanced_v1'\n)\n\nenhanced_tuner.search(enhanced_train_gen, validation