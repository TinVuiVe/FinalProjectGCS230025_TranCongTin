on='relu', name='dense_classifier')(merged)\n    z = Dropout(0.5)(z)\n    \n    final_output = Dense(1, activation='sigmoid', name='final_output')(z)\n    \n    model = Model(inputs=[image_input, vector_input], outputs=final_output, name=\"Model3_Baseline_Sobel\")\n    return model\n\nmodel_3_sobel = build_model_3_sobel()\n\nmodel_3_sobel.compile(\n    optimizer=Adam(learning_rate=0.001),\n    loss='binary_crossentropy',\n    metrics=['accuracy']\n)\n\nmodel_3_sobel.summary()","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 4.2.1: Train Model 2 - DenseNet121 (Sobel Weights) + Softmax Vector","metadata":{}},{"cell_type":"code","source":"from tensorflow.keras.callbacks import ModelCheckpoint, EarlyStopping, CSVLogger\n\ncheckpoint_path_3 = \"model3_baseline_sobel_best.keras\"\ncsv_log_path_3 = \"training_logs_model3_baseline_sobel.csv\"\n\ncallbacks_3 = [\n    ModelCheckpoint(\n        filepath=checkpoint_path_3,\n        monitor='val_accuracy', \n        save_best_only=True,    \n        mode='max',\n        verbose=1\n    ),\n    EarlyStopping(\n        monitor='val_loss',     \n        patience=5,             \n        restore_best_weights=True,\n        verbose=1\n    ),\n    CSVLogger(\n        filename=csv_log_path_3,  \n        separator=',',\n        append=False            \n    )\n]\n\nprint(\"Starting training for Model 3 Baseline (Sobel Image + Vector)...\")\nepochs = 20 \n\nhistory_3 = model_3_sobel.fit(\n    train_gen_sobel,                  \n    validation_data=valid_gen_sobel,    \n    epochs=epochs,\n    callbacks=callbacks_3,\n    verbose=1\n)\n\nprint(f\"\\nTraining completed successfully! Logs are saved to {csv_log_path_3}\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 4.2.2: Model 2 - DenseNet121 (Sobel Weights) + Softmax Vector Evaluation","metadata":{}},{"cell_type":"code","source":"import numpy as np\nimport pandas as pd\n