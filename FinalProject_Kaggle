blurred_img, lower, upper)\n    \n    return cv2.cvtColor(edges_canny, cv2.COLOR_GRAY2RGB)\n\n# Sobel\ndef apply_sobel_eda(img):\n    if len(img.shape) == 3:\n        img = cv2.cvtColor(img, cv2.COLOR_RGB2GRAY)\n        \n    clahe = cv2.createCLAHE(clipLimit=3.0, tileGridSize=(8,8))\n    enhanced_img = clahe.apply(img)\n    blurred_img = cv2.GaussianBlur(enhanced_img, (5, 5), 0)\n\n    sobel_x = cv2.Sobel(blurred_img, cv2.CV_64F, 1, 0)\n    sobel_y = cv2.Sobel(blurred_img, cv2.CV_64F, 0, 1)\n    edges_sobel = normalize_and_brighten(cv2.magnitude(sobel_x, sobel_y))\n    \n    return cv2.cvtColor(edges_sobel, cv2.COLOR_GRAY2RGB)\n\n# Laplacian\ndef apply_laplacian_eda(img):\n    if len(img.shape) == 3:\n        img = cv2.cvtColor(img, cv2.COLOR_RGB2GRAY)\n        \n    clahe = cv2.createCLAHE(clipLimit=3.0, tileGridSize=(8,8))\n    enhanced_img = clahe.apply(img)\n    blurred_img = cv2.GaussianBlur(enhanced_img, (5, 5), 0)\n\n    edges_laplacian = normalize_and_brighten(np.absolute(cv2.Laplacian(blurred_img, cv2.CV_64F)))\n    \n    return cv2.cvtColor(edges_laplacian, cv2.COLOR_GRAY2RGB)\n\n\nclass EdgeDataGenerator(Sequence):\n    def __init__(self, df, x_col, y_col, batch_size=32, target_size=(224, 224), \n                 num_classes=7, augment=False, edge_filter=None, **kwargs):\n        super().__init__(**kwargs) # Sua loi UserWarning cua Keras 3 tai day\n        \n        self.df = df.reset_index(drop=True)\n        self.x_col = x_col\n        self.y_col = y_col\n        self.batch_size = batch_size\n        self.target_size = target_size\n        self.num_classes = num_classes\n        self.augment = augment\n        self.edge_filter = edge_filter \n        \n        self.indices = np.arange(len(self.df))\n        if self.augment:\n            self.transform = A.Compose([\n                A.Rotate(limit=15, p=0.5),\n                A.HorizontalFlip(p=0.5),\n                A.RandomBrightnessContrast(p=0.2),\n            ])\n            np.random.shuffle(self.indices)\n\n    def __len__(self):\n        return int(np.ceil(len(self.df) / self.batch_size))\n\n    def on_epoch_end(self):\n        if self.augment:\n            np.random.shuffle(self.indices)\n\n    def __getitem__(self, index):\n        start_idx = index * self.batch_size\n        end_idx = min((index + 1) * self.batch_size, len(self.df))\n        batch_indices = self.indices[start_idx:end_idx]\n\n        X, y = [], []\n        for i in batch_indices:\n            img_path = self.df[self.x_col].iloc[i]\n            label = self.df[self.y_col].iloc[i]\n\n            img = cv2.imread(img_path)\n            img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)\n            img = cv2.resize(img, self.target_size)\n\n            if self.edge_filter is not None:\n                img = self.edge_filter(img)\n\n            if self.augment:\n                img = self.transform(image=img)['image']\n\n            img = img / 255.0\n\n            X.append(img)\n            y.append(label)\n\n        X = np.array(X, dtype=np.float32)\n        y = tf.keras.utils.to_categorical(y, num_classes=self.num_classes)\n        return X, y\n\nprint(\"Initialized preprocessing functions and EdgeDataGenerator successfully.\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-26T14:54:04.21551Z","iopub.execute_input":"2026-04-26T14:54:04.216414Z","iopub.status.idle":"2026-04-26T14:54:11.989946Z","shell.execute_reply.started":"2026-04-26T14:54:04.216381Z","shell.execute_reply":"2026-04-26T14:54:11.989291Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 16: DenseNet121 - Canny","metadata":{}},{"cell_type":"code","source":"import tensorflow as tf\nfrom tensorflow.keras.applications import DenseNet121\nfrom tensorflow.keras.models import Model\nfrom tensorflow.keras.layers import Dense, GlobalAveragePooling2D, Dropout\nfrom tensorflow.keras.optimizers import Adam\nfrom tensorflow.keras.callbacks import ModelCheckpoint, EarlyStopping, ReduceLROnPl