rt Adam\nfrom tensorflow.keras.callbacks import EarlyStopping, ModelCheckpoint, CSVLogger\n\ninputs_eff = Input(shape=(224, 224, 3))\nx_eff = data_aug_r6(inputs_eff)\nbase_model_eff = EfficientNetB0(weights='imagenet', include_top=False, input_tensor=x_eff)\n\n# Fine-tuning: Mở khóa 20 lớp cuối\nbase_model_eff.trainable = True\nfor layer in base_model_eff.layers[:-20]:\n    layer.trainable = False\n\nx = base_model_eff.output\nx = GlobalAveragePooling2D()(x)\nx = Dropout(0.2)(x)\npreds_eff = Dense(7, activation='softmax')(x)\n\nmodel_efficientnet = Model(inputs=inputs_eff, outputs=preds_eff)\n\nmodel_efficientnet.compile(optimizer=Adam(learning_rate=1e-5), \n                           loss='sparse_categorical_crossentropy', metrics=['accuracy'])\n\ncallbacks_eff = [\n    EarlyStopping(monitor='val_loss', patience=3, restore_best_weights=True),\n    ModelCheckpoint('model_3.2_efficientnetb0.keras', monitor='val_accuracy', save_best_only=True),\n    CSVLogger('log_3.2_efficientnetb0.csv')\n]\n\nprint(\"Starting Training: EfficientNetB0...\")\nhistory_efficientnet = model_efficientnet.fit(train_gen_baseline, validation_data=valid_gen_baseline, epochs=20, callbacks=callbacks_eff, class_weight=class_weights_dict)","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 14: Evaluation All Suitable Model","metadata":{}},{"cell_type":"code","source":"import pandas as pd\nimport numpy as np\nimport matplotlib.pyplot as plt\nimport seaborn as sns\nfrom sklearn.metrics import confusion_matrix, classification_report\nfrom tensorflow.keras.models import load_model\nimport tensorflow as tf\n\ny_true_classes = valid_gen_baseline.dataframe['label_idx'].values\n\ntarget_names = ['XR_ELBOW', 'XR_FINGER', 'XR_FOREARM', 'XR_HAND', 'XR_HUMERUS', 'XR_SHOULDER', 'XR_WRIST']\n\ndef evaluate_and_save_single_model(model_title, model_path, log_path, prefix_name):\n    print(f\"\\nEvaluating model: {model_title}\")\n    print(\"-\" * 50)\n\n    try:\n        log_data = pd.read_csv(log_path)\n        max_loss = max(max(log_data['loss']), max(log_data['val_loss']))\n\n        fig, axes = plt.subplots(1, 2, figsize=(16, 6))\n\n        axes[0].plot(log_data['accuracy'], label='Train Accuracy', color='darkgreen')\n        axes[0].plot(log_data['val_accuracy'], label='Validation Accuracy', color='limegreen')\n        axes[0].set_title(f'{model_title}: Accuracy Curves')\n        axes[0].set_ylabel('Accuracy')\n        axes[0].set_xlabel('Epoch')\n        axes[0].set_ylim(0, 1) \n        axes[0].legend(loc='lower right')\n        axes[0].grid(True)\n\n        # Loss Curve\n        axes[1].plot(log_data['loss'], label='Train Loss', color='darkgreen')\n        axes[1].plot(log_data['val_loss'], label='Validation Loss', color='limegreen')\n        axes[1].set_title(f'{model_title}: Loss Curves')\n        axes[1].set_ylabel('Loss')\n        axes[1].set_xlabel('Epoch')\n        axes[1].set_ylim(0, max_loss * 1.1) \n        axes[1].legend(loc='upper right')\n        axes[1].grid(True)\n\n        plt.tight_layout()\n        curve_img = f'plot_{prefix_name}_learning_curves.png'\n        plt.savefig(curve_img, dpi=300, bbox_inches='tight')\n        print(f\"Saved: {curve_img}\")\n        plt.show()\n    except Exception as e:\n        print(f\"Error plotting learning curves: {e}\")\n\n    print(f\"Loading model from {model_path} and generating predictions...\")\n    try:\n        model = load_model(model_path)\n        y_pred_probs = model.predict(valid_gen_baseline)\n        y_pred_classes = np.argmax(y_pred_probs, axis=1)\n\n        # --- 3. Plot and save Confusion Matrix ---\n        cm = confusion_matrix(y_true_classes, y_pred_classes)\n\n        plt.figure(figsize=(10, 8))\n        sns.heatmap(cm, annot=True, fmt='d', cmap='Blues',\n                    xticklabels=target_names, yticklabels=target_names)\n        plt.title(f'{model_title}: Confusion Matrix')\n        plt.ylabel('True Label')\n        plt.xlabel('Predicted Label')\n        plt.xticks(rotation=45)\n        plt.tight_layout()\n        \n        cm_img = f'plot_{prefix_name}_confusion_matrix.png'\n        plt.savefig(cm_img, dpi=300, bbox_inches='tight')\n        print(f\"Saved: {cm_img}\")\n        plt.show()\n\n        print(f\"\\nClassification Report for {model_title}:\")\n        \n        report_str = classification_report(y_true_classes, y_pred_classes, target_names=target_names)\n        print(report_str)\n        \n        report_dict = classification_report(y_true_classes, y_pred_classes, target_names=target_names, output_dict=True)\n        \n        report_df = pd.DataFrame(report_dict).transpose()\n        \n        report_csv = f'report_{prefix_name}.csv'\n        report_df.to_csv(report_csv)\n        print(f\"Saved: {report_csv}\")\n        \n    except Exception as e:\n        print(f\"Error evaluating model: {e}\")\n    \n    tf.keras.backend.clear_session()\n    print(\"Session cleared.\")\n\nevaluate_and_save_single_model(\n    model_title=\"ResNet50\", \n    model_path='/kaggle/input/datasets/tintrancong/models-saved/Models/model_resnet50.keras', \n    log_path='/kaggle/input/datasets/tintrancong/logs-saved/Logs/log_resnet50.csv', \n    prefix_name='resnet50'\n)\n\nevaluate_and_save_single_model(\n    model_title=\"DenseNet121\", \n    model_path='/kaggle/input/datasets/tintrancong/models-saved/Models/model_densenet121.keras', \n    log_path='/kaggle/input/datasets/tintrancong/logs-saved/Logs/log_densenet121.csv', \n    prefix_name='densenet121'\n)\n\nevaluate_and_save_single_model(\n    model_title=\"EfficientNetB0\", \n    model_path='/kaggle/input/datasets/tintrancong/models-saved/Models/model_efficientnetb0.keras', \n    log_path='/kaggle/input/datasets/tintrancong/logs-saved/Logs/log_efficientnetb0.csv', \n    prefix_name='efficientnetb0'\n)\n\nevaluate_and_save_single_model(\n    model_title=\"Basic CNN\", \n    model_path='/kaggle/input/datasets/tintrancong/models-saved/Models/model_basic_cnn.keras', \n    log_path='/kaggle/input/datasets/tintrancong/logs-saved/Logs/log_basic_cnn.csv', \n    prefix_name='basic_cnn'\n)","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 14.1 Comparison","metadata":{}},{"cell_type":"code","source":"import os\nimport gc\nimport cv2\nimport numpy as np\nimport pandas as pd\nimport tensorflow as tf\nfrom tensorflow.keras.models import load_model\nimport matplotlib.pyplot as plt\nfrom sklearn.metrics import accuracy_score, precision_score, recall_score, f1_score\n\nfrom tensorflow.keras.applications.mobilenet_v2 import preprocess_input\n\nprint(\"--- Start Evaluating (MODEL 1 - STAGE 2: FIXED PREPROCESSING) ---\")\n\nmodel_dict_stage2 = {\n    \"Basic CNN\": \"/kaggle/input/datasets/tintrancong/models-saved/Models/model_basic_cnn.keras\",\n    \"DenseNet121\": \"/kaggle/input/datasets/tintrancong/models-saved/Models/model_densenet121.keras\",\n    \"ResNet50\": \"/kaggle/input/datasets/tintrancong/models-saved/Models/model_resnet50.keras\",\n    \"EfficientNetB0\": \"/kaggle/input/datasets/tintrancong/models-saved/Models/model_efficientnetb0.keras\"\n}\n\nprint(\"\\nWaiting... Nạp và tiền xử lý ảnh\")\nX_eval_s2 = []\ny_true_s2 = final_valid_df['label_idx'].values \nTARGET_SIZE = (224, 224)\n\nfor index, row in final_valid_df.iterrows():\n    img_path = row['img_path'] \n    \n    img = cv2.imread(img_path)\n    if img is None:\n        img = np.zeros((*TARGET_SIZE, 3), dtype=np.float32)\n    else:\n        img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)\n        img = cv2.resize(img, TARGET_SIZE)\n        \n    img = preprocess_input(img.astype(np.float32))\n    X_eval_s2.append(img)\n\nX_eval_s2 = np.array(X_eval_s2)\nprint(f\"-> Nạp xong! Kích thước mảng X_eval_s2: {X_eval_s2.shape}\")\n\nresults_list_s2 = []\n\nfor model_name, model_path in model_dict_stage2.items():\n    print(f\"\\n[{model_name}] Đang dự đoán...\")\n    \n    try:\n        model = load_model(model_path)\n        y_pred_prob = model.predict(X_eval_s2, batch_size=32, verbose=0)\n        y_pred = np.argmax(y_pred_prob, axis=1)\n        \n        acc = accuracy_score(y_true_s2, y_pred)\n        prec = precision_score(y_true_s2, y_pred, average='macro', zero_division=0)\n        rec = recall_score(y_true_s2, y_pred, average='macro', zero_division=0)\n        f1 = f1_score(y_true_s2, y_pred, average='macro', zero_division=0)\n        \n        results_list_s2.append({\n            \"Model\": model_name,\n            \"Accuracy\": acc,\n            \"Precision (Macro)\": prec,\n            \"Recall (Macro)\": rec,\n            \"F1-Score (Macro)\": f1\n        })\n        \n        print(f\"-> Hoàn tất {model_name}: Acc={acc:.4f}, F1={f1:.4f}\")\n        \n        del model\n        tf.keras.backend.clear_session()\n        gc.collect()\n        \n    except Exception as e:\n        print(f\"-> Error {model_name}: {e}\")\n\nreport_df_s2 = pd.DataFrame(results_list_s2)\nreport_df_s2.to_csv('/kaggle/working/model1_stage2_comparison_valid.csv', index=False)\nprint(\"\\n--- Result for Model 1 - Stage 2 (Validation Set) ---\")\nprint(report_df_s2.to_string(index=False))\n\nreport_rounded_s2 = report_df_s2.copy()\nfor col in [\"Accuracy\", \"Precision (Macro)\", \"Recall (Macro)\", \"F1-Score (Macro)\"]:\n    report_rounded_s2[col] = report_rounded_s2[col].apply(lambda x: f\"{x:.4f}\")\n\nfig, ax = plt.subplots(figsize=(10, 3.5)) \nax.axis('off') \n\ncol_widths = [0.35, 0.1625, 0.1625, 0.1625, 0.1625]\n\ntable = ax.table(cellText=report_rounded_s2.values,\n                 colLabels=report_rounded_s2.columns,\n                 cellLoc='center',\n                 loc='center',\n                 colWidths=col_widths,\n                 bbox=[0, 0, 1, 1])\n\ntable.auto_set_font_size(False)\ntable.set_fontsize(11)\n\nfor (row, col), cell in table.get_celld().items():\n    if row == 0:\n        cell.set_text_props(weight='bold', color='white')\n        cell.set_facecolor('#4a2b56') \n    else:\n        if col == 0:\n            cell.set_text_props(ha='left')\n            \n        if row % 2 == 0:\n            cell.set_facecolor('#f4f4f4')\n        else:\n            cell.set_facecolor('#ffffff')\n\nplt.title('Stage 2 Architecture Comparison on Validation Set (7 Body Regions)', \n          fontsize=14, fontweight='bold', pad=20)\n\nplt.tight_layout()\nplt.savefig('/kaggle/working/model1_stage2_comparison_table.png', dpi=300, bbox_inches='tight')\nplt.show()\n\nprint(\"\\n-> Done\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-26T12:16:21.335126Z","iopub.execute_input":"2026-04-26T12:16:21.336016Z","iopub.status.idle":"2026-04-26T12:19:11.517292Z","shell.execute_reply.started":"2026-04-26T12:16:21.335983Z","shell.execute_reply":"2026-04-26T12:19:11.516474Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# Part 3.3: Edge Detection Evaluation ","metadata":{}},{"cell_type":"markdown","source":"## Cell 15: Edge Data Generator","metadata":{}},{"cell_type":"code","source":"import cv2\nimport numpy as np\nimport tensorflow as tf\nfrom tensorflow.keras.utils import Sequence\nimport albumentations as A\n\n# Ham ho tro tang sang cho Sobel va Laplacian\ndef normalize_and_brighten(image):\n    p99 = np.percentile(image, 99.5)\n    clipped = np.clip(image, 0, p99)\n    return cv2.normalize(clipped, None, 0, 255, cv2.NORM_MINMAX).astype(np.uint8)\n\n# Canny (co CLAHE va Blur)\ndef apply_canny_eda(img):\n    if len(img.shape) == 3:\n        img = cv2.cvtColor(img, cv2.COLOR_RGB2GRAY)\n        \n    clahe = cv2.createCLAHE(clipLimit=3.0, tileGridSize=(8,8))\n    enhanced_img = clahe.apply(img)\n    blurred_img = cv2.GaussianBlur(enhanced_img, (5, 5), 0)\n\n    v = np.median(blurred_img)\n    sigma = 0.33\n    lower = int(max(0, (1.0 - sigma) * v))\n    upper = int(min(255, (1.0 + sigma) * v))\n    edges_canny = cv2.Canny(blurred_img, lower, upper)\n    \n    return cv2.cvtColor(edges_canny, cv2.COLOR_GRAY2RGB)\n\n# Sobel\ndef apply_sobel_eda(img):\n    if len(img.shape) == 3:\n        img = cv2.cvtColor(img, cv2.COLOR_RGB2GRAY)\n        \n    clahe = cv2.createCLAHE(clipLimit=3.0, tileGridSize=(8,8))\n    enhanced_img = clahe.apply(img)\n    blurred_img = cv2.GaussianBlur(enhanced_img, (5, 5), 0)\n\n    sobel_x = cv2.Sobel(blurred_img, cv2.CV_64F, 1, 0)\n    sobel_y = cv2.Sobel(blurred_img, cv2.CV_64F, 0, 1)\n    edges_sobel = normalize_and_brighten(cv2.magnitude(sobel_x, sobel_y))\n    \n    return cv2.cvtColor(edges_sobel, cv2.COLOR_GRAY2RGB)\n\n# Laplacian\ndef apply_laplacian_eda(img):\n    if len(img.shape) == 3:\n        img = cv2.cvtColor(img, cv2.COLOR_RGB2GRAY)\n        \n    clahe = cv2.createCLAHE(clipLimit=3.0, tileGridSize=(8,8))\n    enhanced_img = clahe.apply(img)\n    blurred_img = cv2.GaussianBlur(enhanced_img, (5, 5), 0)\n\n    edges_laplacian = normalize_and_brighten(np.absolute(cv2.Laplacian(blurred_img, cv2.CV_64F)))\n    \n    return cv2.cvtColor(edges_laplacian, cv2.COLOR_GRAY2RGB)\n\n\nclass EdgeDataGenerator(Sequence):\n    def __init__(self, df, x_col, y_col, batch_size=32, target_size=(224, 224), \n                 num_classes=7, augment=False, edge_filter=None, **kwargs):\n        super().__init__(**kwargs) # Sua loi UserWarning cua Keras 3 tai day\n        \n        self.df = df.reset_index(drop=True)\n        self.x_col = x_col\n        self.y_col = y_col\n        self.batch_size = batch_size\n        self.target_size = target_size\n        self.num_classes = num_classes\n        self.augment = augment\n        self.edge_filter = edge_filter \n        \n        self.indices = np.arange(len(self.df))\n        if self.augment:\n            self.transform = A.Compose([\n                A.Rotate(limit=15, p=0.5),\n                A.HorizontalFlip(p=0.5),\n                A.RandomBrightnessContrast(p=0.2),\n            ])\n            np.random.shuffle(self.indices)\n\n    def __len__(self):\n        return int(np.ceil(len(self.df) / self.batch_size))\n\n    def on_epoch_end(self):\n        if self.augment:\n            np.random.shuffle(self.indices)\n\n    def __getitem__(self, index):\n        start_idx = index * self.batch_size\n        end_idx = min((index + 1) * self.batch_size, len(self.df))\n        batch_indices = self.indices[start_idx:end_idx]\n\n        X, y = [], []\n        for i in batch_indices:\n            img_path = self.df[self.x_col].iloc[i]\n            label = self.df[self.y_col].iloc[i]\n\n            img = cv2.imread(img_path)\n            img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)\n            img = cv2.resize(img, self.target_size)\n\n            if self.edge_filter is not None:\n                img = self.edge_filter(img)\n\n            if self.augment:\n                img = self.transform(image=img)['image']\n\n            img = img / 255.0\n\n            X.append(img)\n            y.append(label)\n\n        X = np.array(X, dtype=np.float32)\n        y = tf.keras.utils.to_categorical(y, num_classes=self.num_classes)\n        return X, y\n\nprint(\"Initialized preprocessing functions and EdgeDataGenerator successfully.\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-26T14:54:04.21551Z","iopub.execute_input":"2026-04-26T14:54:04.216414Z","iopub.status.idle":"2026-04-26T14:54:11.989946Z","shell.execute_reply.started":"2026-04-26T14:54:04.216381Z","shell.execute_reply":"2026-04-26T14:54:11.989291Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 16: DenseNet121 - Canny","metadata":{}},{"cell_type":"code","source":"import tensorflow as tf\nfrom tensorflow.keras.applications import DenseNet121\nfrom tensorflow.keras.models import Model\nfrom tensorflow.keras.layers import Dense, GlobalAveragePooling2D, Dropout\nfrom tensorflow.keras.optimizers import Adam\nfrom tensorflow.keras.callbacks import ModelCheckpoint, EarlyStopping, ReduceLROnPlateau, CSVLogger\nfrom sklearn.utils.class_weight import compute_class_weight\nimport 