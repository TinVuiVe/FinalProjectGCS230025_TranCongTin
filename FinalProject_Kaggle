elf): return int(np.ceil(len(self.df) / self.batch_size))\n    def on_epoch_end(self): \n        if self.shuffle: np.random.shuffle(self.indices)\n\n    def __getitem__(self, index):\n        batch_indices = self.indices[index * self.batch_size : (index + 1) * self.batch_size]\n        batch_df = self.df.iloc[batch_indices]\n        X, y = [], []\n        BASE_DATA_DIR = '/kaggle/input/datasets/tintrancong/ai-powered-musculoskeletal-injury-dataset/Final_Project_TranCongTinCOS1106' \n\n        for _, row in batch_df.iterrows():\n            img_path = os.path.join(BASE_DATA_DIR, row['img_path']) \n            gray_img = cv2.imread(img_path, cv2.IMREAD_GRAYSCALE)\n            if gray_img is None: continue\n            \n            gray_img = cv2.resize(gray_img, self.target_size)\n            orig = gray_img / 255.0\n            low = cv2.GaussianBlur(gray_img, (5, 5), 0) / 255.0\n            high = cv2.Laplacian(gray_img, cv2.CV_32F)\n            high = cv2.normalize(high, None, 0, 1, cv2.NORM_MINMAX)\n            \n            img_3c = np.stack([orig, low, high], axis=-1)\n            X.append(img_3c)\n            y.append(row['Target_14'])\n\n        X = np.array(X, dtype=np.float32)\n        y = tf.keras.utils.to_categorical(y, num_classes=14)\n        return X, y\n\nclass ViT_HubLayer(tf.keras.layers.Layer):\n    def __init__(self, url=\"https://tfhub.dev/sayakpaul/vit_b16_fe/1\", **kwargs):\n        super().__init__(**kwargs)\n        self.url = url\n        self.model = hub.load(url)\n        self.trainable = False\n    def call(self, inputs): return self.model(inputs)\n    def get_config(self):\n        config = super().get_config()\n        config.update({\"url\": self.url})\n        return config\n\nprint(\"Valid & Test Generators\")\nvalid_gen_14 = DenseNet14ClassGenerator(valid_14_df, batch_size=32, shuffle=False)\ntest_gen_14 = DenseNet14ClassGenerator(test_14_df, batch_size=32, shuffle=False)\n\ny_true_valid = valid_14_df['Target_14'].values\ny_true_tes