        if img is None: continue\n                \n            img = cv2.cvtColor(img, cv2.COLOR_BGR2GRAY) \n            img = cv2.resize(img, self.target_size)\n            img = np.expand_dims(img, axis=-1)\n            img = img.astype(np.float32) / 255.0\n            \n            X_images.append(img)\n            if self.vec_cols:\n                X_vectors.append(row[self.vec_cols].values.astype(np.float32))\n                \n        X_images = np.array(X_images)\n        if self.vec_cols:\n            X_vectors = np.array(X_vectors)\n            return (X_images, X_vectors), X_images # Output: ([Image, Condition], Target_Image)\n        return X_images, X_images\n\n# Generators\nauto_train_gen = ConditionalAutoencoderGenerator(final_train_normal_df, vec_cols=softmax_columns, batch_size=32, shuffle=True)\nauto_valid_gen = ConditionalAutoencoderGenerator(final_valid_df, vec_cols=softmax_columns, batch_size=32, shuffle=False)\nauto_test_gen = ConditionalAutoencoderGenerator(test_df, vec_cols=softmax_columns, batch_size=32, shuffle=False)\n\nprint(\"All Generators are ready!\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-26T20:22:24.598652Z","iopub.execute_input":"2026-04-26T20:22:24.599679Z","iopub.status.idle":"2026-04-26T20:22:24.623721Z","shell.execute_reply.started":"2026-04-26T20:22:24.599645Z","shell.execute_reply":"2026-04-26T20:22:24.622606Z"}},"outputs":[{"name":"stdout","text":"--- STEP 2: INITIALIZING CONDITIONAL GENERATORS ---\nTotal Train images: 28959 | Normal images for Autoencoder: 17249\nAll Generators are ready!\n","output_type":"stream"}],"execution_count":11},{"cell_type":"markdown","source":"## Cell 5.4: HYPERPARAMETER TUNING BEFORE TRAINING","metadata":{}},{"cell_type":"code","source":"!pip install keras-tuner -q\nimport keras_tuner as kt\nfrom tensorflow.keras.layers import Input, Conv2D, Flatten, Dense, Reshape, Conv2DTranspose, Concatenate\nfrom tensorflow.keras.models import Model\nfrom tensorflow.keras.optimizers import Adam\nimport numpy as np\n\nprint(\"--- STEP 3: HYPERPARAMETER TUNING ---\")\n\ndef build_tuner_model(hp):\n    latent_dim = hp.Choice('latent_dim', values=[256, 512])\n    \n    # 1. ENCODER\n    input_img = Input(shape=(224, 224, 1), name='image_input')\n    x = Conv2D(32, (3, 3), activation='relu', padding='same', strides=2)(input_img)   \n    x = Conv2D(64, (3, 3), activation='relu', padding='same', strides=2)(x)           \n    x = Conv2D(128, (3, 3), activation='relu', padding='same', strides=2)(x)          \n    x = Conv2D(128, (3, 3), activation='relu', padding='same', strides=2)(x)          \n    encoded_shape = x.shape[1:] \n    x = Flatten()(x)            \n    latent_vector = Dense(latent_dim, activation='relu', name='latent_features')(x)\n\n    # 2. BOTTLENECK\n    input_cond = Input(shape=(7,), name='condition_input')\n    merged_vector = Concatenate(name='merge_features_and_condition')([latent_vector, input_cond])\n\n    # 3. DECODER\n    x = Dense(np.prod(encoded_shape), activation='relu')(merged_vector)\n    x = Reshape(encoded_shape)(x)\n    x = Conv2DTranspose(128, (3, 3), activation='relu', padding='same', strides=2)(x) \n    x = Conv2DTranspose(64, (3, 3), activation='relu', padding='same', strides=2)(x)  \n    x = Conv2DTranspose(32, (3, 3), activation='relu', padding='same', strides=2)(x)  \n    decoded_img = Conv2DTranspose(1, (3, 3), activation='sigmoid', padding='same', strides=2, name='reconstructed_image')(x)\n\n    autoencoder = Model(inputs=[input_img, input_cond], outputs=decoded_img)\n    \n    hp_learning_rate = hp.Choice('learning_rate', values=[1e-3, 1e-4, 1e-5])\n    autoencoder.compile(optimizer=Adam(learning_rate=hp_learning_rate), loss='mse')\n    \n    return autoencoder\n\ntuner = kt.RandomSearch(\n    build_tuner_model,\n    objective='val_loss',\n    max_trials=3,\n    executions_per_trial=1,\n    directory='autoencoder_tuning',\n    project_name='bone_anomaly'\n)\n\ntuner.search(auto_train_gen, validation_data