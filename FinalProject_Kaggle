edict(valid_gen, verbose=1)\ny_pred = (y_pred_prob > 0.5).astype(int).flatten()\n\nLABEL_COL = 'label' if 'label' in valid_df.columns else 'Label'\ny_true = valid_df[LABEL_COL].values \n\n# 3. In va LUU Bao cao phan loai ra file CSV\nprint(\"\\n--- 3. Classification Report ---\")\nreport_text = classification_report(y_true, y_pred, target_names=['Normal (0)', 'Abnormal (1)'])\nprint(report_text)\n\n# Lay data dang Dictionary, chuyen thanh bang (DataFrame) va luu CSV\nreport_dict = classification_report(y_true, y_pred, target_names=['Normal (0)', 'Abnormal (1)'], output_dict=True)\nreport_df = pd.DataFrame(report_dict).transpose() # transpose de xoay chieu bang cho dung chuan\n\nreport_df.to_csv('classification_report_model2_baseline.csv', index=True)\nprint(\"Saved classification report to 'classification_report_model2_baseline.csv'\")\n\n# 4. Ve va LUU Ma tran nham lan (Confusion Matrix)\nprint(\"\\n--- 4. Confusion Matrix ---\")\ncm = confusion_matrix(y_true, y_pred)\nplt.figure(figsize=(6, 5))\nsns.heatmap(cm, annot=True, fmt='d', cmap='Blues', \n            xticklabels=['Normal', 'Abnormal'], \n            yticklabels=['Normal', 'Abnormal'])\nplt.xlabel('Predicted Label')\nplt.ylabel('True Label')\nplt.title('Confusion Matrix - Baseline Original')\n\n# LUU FILE ANH TRUOC KHI SHOW\nplt.savefig('confusion_matrix_model2_baseline.png', dpi=300)\nprint(\"Saved confusion matrix plot to 'confusion_matrix_model2_baseline.png'\")\n\nplt.show()","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 4.1.3: Model 2_Baseline_DenseNet121 (Original Images) - Fine-Tune stage 2","metadata":{}},{"cell_type":"code","source":"import tensorflow as tf\nfrom tensorflow.keras.optimizers import Adam\n\ntf.keras.backend.clear_session()\n\nprint(\"--- 1. Preparing for Fine-tuning (Fresh Build) ---\")\nmodel_2_finetune = build_multi_input_model()\n\ncheckpoint_baseline = \"/kaggle/input/datasets/tintrancong/model-saved/Models/model2_base