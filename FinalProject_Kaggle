0, 255, cv2.NORM_MINMAX, dtype=cv2.CV_8U)\n    return cv2.cvtColor(sobel_normalized, cv2.COLOR_GRAY2RGB)\n\ndef triage_image(image):\n    if image is None or not models_loaded:\n        return None, None, None, \"🚫 **Error:** Invalid image or models not loaded.\"\n\n    img_resized = cv2.resize(image, (224, 224))\n    \n    # STAGE 1: DENSENET + SOBEL\n    img_sobel = apply_sobel(img_resized)\n    img_input_m1 = img_sobel.astype(np.float32) / 255.0\n    img_input_m1 = np.expand_dims(img_input_m1, axis=0) \n    \n    try:\n        preds_m1 = model_1.predict(img_input_m1, verbose=0)[0]\n    except Exception as e:\n        return None, None, None, f\"Model 1 Error: {e}\"\n        \n    class_probs_dict_7c = {region: float(prob) for region, prob in zip(anatomical_regions, preds_m1)}\n    \n    # STAGE 2: DENSENET REG L2 (RAW IMAGE)\n    img_input_m2 = preprocess_input(img_resized.astype(np.float32))\n    img_input_m2 = np.expand_dims(img_input_m2, axis=0) \n    cond_vector = np.expand_dims(preds_m1, axis=0)\n\n    try:\n        preds_m2 = model_2.predict([img_input_m2, cond_vector], verbose=0)\n        prob_abnormal = float(preds_m2[0][0])\n        prob_normal = 1.0 - prob_abnormal\n        status = \"Abnormal\" if prob_abnormal >= 0.5 else \"Normal\"\n    except Exception as e:\n        return None, None, None, f\"Model 2 Error: {e}\"\n    \n    anomaly_probs_dict = {\"Abnormal\": prob_abnormal, \"Normal\": prob_normal}\n    \n    # INTERPRETATION\n    top_region = max(class_probs_dict_7c, key=class_probs_dict_7c.get)\n    interpretation = f\"### 📌 Interpretation Summary\\n\\n\"\n    interpretation += f\"**Anatomical View Identification:** Identified as **{top_region}**.\\n\\n\"\n    if status == \"Abnormal\": \n        interpretation += f\"**Diagnostic Prediction:** Abnormality detected (**⚠️ ABNORMAL**) ({prob_abnormal:.2%}).\\n\"\n    else: \n        interpretation += f\"**Diagnostic Prediction:** No abnormalities detected (**✅ NORMAL**) ({prob_normal:.2%}).\\n\"\n\n    return class_probs_dict_7c, anomaly_probs_dict, interpretation, img_sobel\n\n\n# CUSTOM CSS & GRADIO UI\ncustom_css = \"\"\"\nbody, .gradio-container {\n    background-color: #f1f5f9 !important; /* Xanh xám nhạt rất clean */\n}\n.header-banner {\n    background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);\n    padding: 24px;\n    border-radius: 12px;\n    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);\n    color: white !important;\n    margin-bottom: 20px;\n}\n.header-banner h1, .header-banner p {\n    color: white !important;\n    margin: 0;\n}\n.dashboard-card {\n    background-color: white !important;\n    border-radius: 12px !important;\n    padding: 20px !important;\n    box-shadow: 0 2px 8px rgba(0,0,0,0.05) !important;\n    border: 1px solid #e2e8f0 !important;\n}\n\"\"\"\n\nmedical_theme = gr.themes.Soft(\n    primary_hue=\"orange\", secondary_hue=\"slate\", neutral_hue=\"slate\"\n).set(button_primary_text_color='white')\n\nwith gr.Blocks(title=\"MSK AI Dashboard\", theme=medical_theme, css=custom_css) as demo:\n    \n    with gr.Column(elem_classes=\"header-banner\"):\n        gr.Markdown(\"# 🏥 **MSK AI Diagnostic Dashboard**\")\n        gr.Markdown(\"Automated Two-Stage Triage System for Musculoskeletal Radiographs\")\n            \n    with gr.Row():\n        with gr.Column(scale=1, elem_classes=\"dashboard-card\"): \n            gr.Markdown(\"### ⚙️ Study Parameters\")\n            gr.Markdown(\"**Report ID:** `Auto-Generated`\\n\"\n                        \"**System Version:** `v2.0 (Two-Stage)`\\n\"\n                        \"**Modality:** `Digital Radiography`\")\n            gr.Markdown(\"---\")\n            gr.Markdown(\"#### **Pipeline Architecture**\")\n            gr.Markdown(\"1️⃣ **Stage 1 (Anatomical):**\\nDenseNet121 + Sobel Edge Detector.\\n\\n\"\n                        \"2️⃣ **Stage 2 (Abnormality):**\\nDenseNet121 + L2 Reg Fusion.\")\n            \n            with gr.Accordion(\"🔧 Developer Debug View\", open=False):\n                debug_sobel_img = gr.Image(label=\"Sobel Edge Map\", interactive=False)\n            \n        with gr.Column(scale=3):\n            # Hàng trên: Input và Result (Dạng Thẻ - Card)\n            with gr.Row(elem_classes=\"dashboard-card\"):\n                with gr.Column(scale=1):\n                    gr.Markdown(\"### **1. Input Scan**\")\n                    input_img = gr.Image(label=\"Upload X-ray (DICOM/JPG/PNG)\", type=\"numpy\")\n                    submit_btn = gr.Button(\"🔍 Run AI Analysis\", variant=\"primary\")\n                \n                with gr.Column(scale=1):\n                    gr.Markdown(\"### **2. Triage Results**\")\n                    output_class_label = gr.Label(label=\"Stage 1: Anatomical Probabilities\", num_top_classes=3)\n                    gr.Markdown(\"<br>\")\n                    output_anomaly_label = gr.Label(label=\"Stage 2: Abnormality Confidence\", num_top_classes=2)\n            \n            gr.Markdown(\"<br>\")\n            with gr.Row(elem_classes=\"dashboard-card\"):\n                with gr.Column():\n                    output_text = gr.Markdown(label=\"Automated Report\")\n            \n            # Footer\n            gr.Markdown(\"<br><center><small><i>⚠️ Disclaimer: This system is for research and triage prioritization only. Not for final clinical diagnosis.</i></small></center>\")\n\n    submit_btn.click(\n        fn=triage_image, \n        inputs=input_img, \n        outputs=[output_class_label, output_anomaly_label, output_text, debug_sobel_img]\n    )\n\ndemo.launch(share=True, debug=True)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-29T10:45:05.118483Z","iopub.execute_input":"2026-04-29T10:45:05.119079Z","execution_failed":"2026-04-29T10:54:47.863Z"}},"outputs":[{"name":"stderr","text":"2026-04-29 10:45:17.759669: E external/local_xla/xla/stream_executor/cuda/cuda_fft.cc:467] Unable to register cuFFT factory: Attempting to register factory for plugin cuFFT when one has already