ed":"2026-04-26T20:02:49.500267Z","shell.execute_reply":"2026-04-26T20:02:53.486226Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 5: DATA - DEFINE TEST SET ","metadata":{}},{"cell_type":"code","source":"test_df = valid_df.copy()\n\ntrain_ids = set(final_train_df['Patient_ID'].unique())\nvalid_ids = set(final_valid_df['Patient_ID'].unique())\ntest_ids = set(test_df['Patient_ID'].unique())\n\nleak_train_test = train_ids.intersection(test_ids)\nleak_valid_test = valid_ids.intersection(test_ids)\n\nprint(\"CELL 5 COMPLETE: TEST SET DEFINED.\")\nprint(\"Test dataset shape:\", test_df.shape)\nprint(\"Overlap Train vs Test:\", len(leak_train_test))\nprint(\"Overlap Valid vs Test:\", len(leak_valid_test))\n\nif len(leak_train_test) == 0 and len(leak_valid_test) == 0:\n    print(\"-> SUCCESS: ALL 3 SETS ARE COMPLETELY INDEPENDENT!\")\nelse:\n    print(\"-> WARNING: DATA LEAKAGE DETECTED IN TEST SET!\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-26T20:02:55.986318Z","iopub.execute_input":"2026-04-26T20:02:55.987238Z","iopub.status.idle":"2026-04-26T20:02:56.001567Z","shell.execute_reply.started":"2026-04-26T20:02:55.987204Z","shell.execute_reply":"2026-04-26T20:02:56.000668Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 6: EDA - DATASET STATISTICS AND DISTRIBUTION","metadata":{}},{"cell_type":"code","source":"def print_statistics(df, set_name):\n    print(f\"--- {set_name.upper()} SET STATISTICS ---\")\n    \n    total_images = len(df)\n    total_patients = df['Patient_ID'].nunique()\n    print(f\"Total Images: {total_images}\")\n    print(f\"Total Patients: {total_patients}\")\n    \n    label_counts = df['Label'].value_counts().to_dict()\n    print(f\"Label Distribution: Normal (0): {label_counts.get(0, 0)} | Abnormal (1): {label_counts.get(1, 0)}\")\n    \n    print(\"Body Part Distribution (Images):\")\n    part_counts = df['Body_Part'].value_counts()\n    for part, count in part_counts.items():\n        print(f\"  - {part}: {count}\")\n    print(\"-\" * 40 + \"\\n\")\n\nprint_statistics(final_train_df, \"Train\")\nprint_statistics(final_valid_df, \"Validation\")\nprint_statistics(test_df, \"Test\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-26T20:02:58.955676Z","iopub.execute_input":"2026-04-26T20:02:58.956444Z","iopub.status.idle":"2026-04-26T20:02:58.976357Z","shell.execute_reply.started":"2026-04-26T20:02:58.95641Z","shell.execute_reply":"2026-04-26T20:02:58.975677Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# Part 2: EDGE DETECTION & FREQUENCY DOMAIN ANALYSIS","metadata":{}},{"cell_type":"markdown","source":"## Cell 7: EDA - EDGE DETECTION & FREQUENCY DOMAIN ANALYSIS","metadata":{}},{"cell_type":"code","source":"import cv2\nimport numpy as np\nimport matplotlib.pyplot as plt\nimport pywt  \nfrom scipy.fftpack import fft2, fftshift\nfrom scipy import signal\n\nabnormal_path = \"/kaggle/input/datasets/tintrancong/ai-powered-musculoskeletal-injury-dataset/Final_Project_TranCongTinCOS1106/MURA-v1.1/train/XR_FINGER/patient00238/study1_positive/image1.png\"\nnormal_path = \"/kaggle/input/datasets/tintrancong/ai-powered-musculoskeletal-injury-dataset/Final_Project_TranCongTinCOS1106/MURA-v1.1/train/XR_FINGER/patient00234/study2_negative/image2.png\" \n\nimage_paths = [(\"NORMAL WRIST\", normal_path), (\"ABNORMAL WRIST\", abnormal_path)]\n\ndef process_and_visualize(title, img_path):\n    # 1. Read and Resize\n    img = cv2.imread(img_path, cv2.IMREAD_GRAYSCALE)\n    if img is None:\n        print(f\"[ERROR] Cannot read: {img_path}\")\n        return\n    img = cv2.resize(img, (256, 256))\n    \n    # 2. CLAHE Enhancement\n    clahe = cv2.createCLAHE(clipLimit=3.0, tileGridSize=(8,8))\n    enhanced_img = clahe.apply(img)\n    blurred_img = cv2.GaussianBlur(enhanced_img, (5, 5), 0)\n\n    # SPATIAL DOMAIN \n    # Canny\n    v = np.median(blurred_img)\n    sigma = 0.33\n    lower = int(max(0, (1.0 - sigma) * v))\n    upper = int(min(255, (1.0 + sigma) * v))\n    edges_canny = cv2.Canny(blurred_img, lower, upper)\n    \n    # Brighten function for Sobel/Laplacian (Reuse your 99.5% percentile logic)\n    def normalize_and_brighten(image):\n        p99 = np.percentile(image, 99.5)\n        clipped = np.clip(image, 0, p99)\n        return cv2.normalize(clipped, None, 0, 255, cv2.NORM_MINMAX).astype(np.uint8)\n\n    # Sobel & Laplacian\n    edges_sobel = normalize_and_brighten(cv2.magnitude(cv2.Sobel(blurred_img, cv2.CV_64F, 1, 0), cv2.Sobel(blurred_img, cv2.CV_64F, 0, 1)))\n    edges_laplacian = normalize_and_brighten(np.absolute(cv2.Laplacian(blurred_img, cv2.CV_64F)))\n\n    # --- FREQUENCY DOMAIN ---\n    # FFT\n    f_shift = fftshift(fft2(enhanced_img))\n    magnitude_spectrum = 20 * np.log(np.abs(f_shift) + 1)\n\n    # Wavelet \n    coeffs2 = pywt.dwt2(enhanced_img, 'haar')\n    LL, (LH, HL, HH) = coeffs2\n    wavelet_details = cv2.normalize(np.log1p(np.abs(LH) + np.abs(HL) + np.abs(HH)), None, 0, 255, cv2.NORM_MINMAX).astype(np.uint8)\n\n    # STFT (Spectrogram)\n    signal_slice = np.mean(enhanced_img[100:150, :], axis=0) \n    f, t, Zxx = signal.stft(signal_slice, fs=1.0, nperseg=64)\n    stft_img = np.abs(Zxx)\n\n    #  (7 columns to include STFT) \n    fig, axes = plt.subplots(1, 7, figsize=(26, 4))\n    fig.suptitle(f'EDA ANALYSIS: {title}', fontsize=16, fontweight='bold', color='darkred')\n\n    # Display results with correct colormaps\n    axes[0].imshow(enhanced_img, cmap='gray'); axes[0].set_title('CLAHE Image')\n    axes[1].imshow(edges_canny, cmap='gray'); axes[1].set_title('Auto-Canny')\n    axes[2].imshow(edges_sobel, cmap='gray'); axes[2].set_title('Sobel (Bright)')\n    axes[3].imshow(edges_laplacian, cmap='gray'); axes[3].set_title('Laplacian (Bright)')\n    axes[4].imshow(magnitude_spectrum, cmap='viridis'); axes[4].set_title('FFT Spectrum')\n    axes[5].imshow(wavelet_details, cmap='magma'); axes[5].set_title('Wavelet Details')\n    axes[6].imshow(stft_img, cmap='inferno'); axes[6].set_title('STFT Spectrogram')\n\n    for ax in axes:\n        ax.axis('off')\n\n    plt.tight_layout()\n    plt.show()\n\n# Execution\ntry:\n    for title, path in image_paths:\n        process_and_visualize(title, path)\nexcept Exception as e:\n    print(f\"[ERROR]: {e}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-26T17:08:10.605424Z","iopub.execute_input":"2026-04-26T17:08:10.606264Z","iopub.status.idle":"2026-04-26T17:08:13.152364Z","shell.execute_reply.started":"2026-04-26T17:08:10.606231Z","shell.execute_reply":"2026-04-26T17:08:13.151424Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# Part 3: BODY-PART CLASSIFICATION (MODEL 1)","metadata":{}},{"cell_type":"markdown","source":"# Part 3.1: Test for the most efficient technique","metadata":{}},{"cell_type":"markdown","source":"## Cell 1: Prepare Labels & Metadata","metadata":{}},{"cell_type":"code","source":"import pandas as pd\nimport numpy as np\nimport matplotlib.pyplot as plt\nimport seaborn as sns\n\n# 1. Fix the image paths by prepending the absolute base directory\nTRUE_BASE_DIR = '/kaggle/input/datasets/tintrancong/ai-powered-musculoskeletal-injury-dataset/Final_Project_TranCongTinCOS1106/'\n\nfinal_train_df['img_path'] = TRUE_BASE_DIR + final_train_df['img_path']\nfinal_valid_df['img_path'] = TRUE_BASE_DIR + final_valid_df['img_path']\ntest_df['img_path'] = TRUE_BASE_DIR + test_df['img_path']\n\nprint(\"Sample absolute path:\")\nprint(final_train_df['img_path'].iloc[0])\nprint(\"-\" * 40)\n\n# 2. Extract body part labels and create mappings\ndef extract_body_part_labels(df):\n    df = df.copy()\n    df['body_part'] = df['img_path'].apply(lambda x: x.split('/')[-4].replace('XR_', ''))\n    \n    body_parts = sorted(df['body_part'].unique())\n    label_map = {part: idx for idx, part in enumerate(body_parts)}\n    \n    df['label_idx'] = df['body_part'].map(label_map)\n    return df, label_map\n\nfinal_train_df, body_part_map = extract_body_part_labels(final_train_df)\nfinal_valid_df, _ = extract_body_part_labels(final_valid_df)\ntest_df, _ = extract_body_part_labels(test_df)\n\nprint(\"Label Mapping:\", body_part_map)\nprint(f\"Train set: {len(final_train_df)} images\")\nprint(f\"Valid set: {len(final_valid_df)} images\")\nprint(f\"Test set: {len(test_df)} images\")\n\n# 3. Visualize class imbalance\nplt.figure(figsize=(10, 5))\nsns.countplot(data=final_train_df, x='body_part', order=body_part_map.keys())\nplt.title(\"Body-Part Distribution (Train Set)\")\nplt.ylabel(\"Number of Images\")\nplt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-26T14:55:02.603209Z","iopub.execute_input":"2026-04-26T14:55:02.604211Z","iopub.status.idle":"2026-04-26T14:55:03.131146Z","shell.execute_reply.started":"2026-04-26T14:55:02.604143Z","shell.execute_reply":"2026-04-26T14:55:03.130306Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 1.1: Import Library for Evaluation","metadata":{}},{"cell_type":"code","source":"import pandas as pd\nimport matplotlib.pyplot as plt\nimport seaborn as sns\nfrom sklearn.metrics import confusion_matrix\nimport numpy as np\n\nprint(\"Libraries loaded. Generating variables based on final_valid_df...\")\ny_true_classes = final_valid_df['label_idx'].values\ntarget_names = list(body_part_map.keys())\n\nprint(f\"Total True Samples: {len(y_true_classes)}\")\nprint(f\"Body Parts List: {target_names}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-26T14:55:07.444496Z","iopub.execute_input":"2026-04-26T14:55:07.445201Z","iopub.status.idle":"2026-04-26T14:55:07.45096Z","shell.execute_reply.started":"2026-04-26T14:55:07.445169Z","shell.execute_reply":"2026-04-26T14:55:07.4501Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## Cell 2: Data Generator","metadata":{}},{"cell_type":"code","source":"import cv2\nfrom tensorflow.keras.utils import Sequence\nfrom tensorflow.keras.applications.mobilenet_v2 import preprocess_input\n\nclass BaselineDataGenerator(Sequence):\n    # Basic generator: reads images, resizes, and applies preprocessing\n    def __init__(self, dataframe, batch_size=32, target_size=(224, 224), shuffle=True):\n        self.dataframe = dataframe.reset_index(drop=True)\n        self.batch_size = batch_size\n        self.target_size = target_size\n        self.shuffle = shuffle\n        self.indices = np.arange(len(self.dataframe))\n        if self.shuffle:\n            np.random.shuffle(self.indices)\n\n    def __len__(self):\n        return int(np.ceil(len(self.dataframe) / self.batch_size))\n\n    def on_epoch_end(self):\n        if self.shuffle:\n            np.random.shuffle(self.indices)\n\n    def __getitem__(self, index):\n        batch_indices = self.indices[index * self.batch_size : (index + 1) * self.batch_size]\n        batch_df = self.dataframe.iloc[batch_indices]\n\n        X = np.empty((len(batch_df), *self.target_size, 3), dtype=np.float32)\n        y = np.empty((len(batch_df)), dtype=int)\n\n        for i, (_, row) in enumerate(batch_df.iterrows()):\n            img_path = row['img_path']\n            img = cv2.imread(img_path)\n            \n            # Handle corrupted or missing images\n            if img is None:\n                img = np.zeros((*self.target_size, 3), dtype=np.uint8)\n            else:\n                img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)\n                img = cv2.resize(img, self.target_size)\n\n            # Preprocess specifically for MobileNetV2 (scales pixels to [-1, 1])\n            X[i,] = preprocess_input(img.astype(np.float32))\n            y[i] = row['label_idx']\n\n        return X, y\n\n# Initialize generators\nBATCH_SIZE = 32\nIMG_SIZE = (224, 224)\n\n# Shuffle training data, but keep validation data ordered\ntrain_gen_baseline = BaselineDataGenerator(final_train_df, batch_size=BATCH_SIZE, target_size=IMG_SIZE, shuffle=True)\nvalid